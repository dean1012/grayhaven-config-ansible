<?xml version="1.0" encoding="utf-8"?>
<zone target="DROP">
  <short>Grayhaven managed inbound policy</short>
  <description>Inbound rules managed by Ansible from the OpenTofu firewall policy.</description>

{% for rule in managed_baseline_firewall_role_policy.inbound | default([]) %}
{% for source_address in rule.source_addresses | default([]) %}
  <rule family="ipv4">
    <source address="{{ source_address }}"/>
    <port protocol="{{ rule.protocol }}" port="{{ rule.port_range }}"/>
    <accept/>
  </rule>
{% endfor %}
{% for source_tag in rule.source_tags | default([]) %}
{% if source_tag == "bastion" %}
{% for source in managed_baseline_web_ssh_sources %}
  <rule family="ipv4">
    <source address="{{ source }}"/>
    <port protocol="{{ rule.protocol }}" port="{{ rule.port_range }}"/>
    <accept/>
  </rule>
{% endfor %}
{% endif %}
{% endfor %}
{% if (rule.source_addresses | default([]) | length == 0) and (rule.source_tags | default([]) | length == 0) %}
  <port protocol="{{ rule.protocol }}" port="{{ rule.port_range }}"/>
{% endif %}
{% endfor %}
</zone>
