// Managed by Ansible. Local changes will be overwritten.

logging {
  level = "info"
}

prometheus.exporter.unix "node" {
  include_exporter_metrics = true
  disable_collectors       = ["mdadm"]
  enable_collectors        = ["systemd"]

  systemd {
    unit_include = "(sshd|firewalld|fail2ban|nginx|grayhaven-restic-backup|grayhaven-restic-check|grayhaven-ansible-runner|grayhaven-ansible-poller)\\.(service|timer)"
    start_time   = true
  }

  textfile {
    directory = {{ observability_textfile_dir | to_json }}
  }
}

prometheus.scrape "node" {
  targets         = prometheus.exporter.unix.node.targets
  scrape_interval = "60s"
  forward_to      = [prometheus.relabel.grayhaven.receiver]
}

{% if grayhaven_role == "web" and observability_web_sites | length > 0 %}
prometheus.exporter.blackbox "http" {
  config = `
modules:
  http_2xx:
    prober: http
    timeout: 5s
    http:
      preferred_ip_protocol: ip4
      valid_status_codes:
        - 200
  http_401:
    prober: http
    timeout: 5s
    http:
      preferred_ip_protocol: ip4
      valid_status_codes:
        - 401
  http_2xx_skip_tls_verify:
    prober: http
    timeout: 5s
    http:
      preferred_ip_protocol: ip4
      tls_config:
        insecure_skip_verify: true
      valid_status_codes:
        - 200
  http_401_skip_tls_verify:
    prober: http
    timeout: 5s
    http:
      preferred_ip_protocol: ip4
      tls_config:
        insecure_skip_verify: true
      valid_status_codes:
        - 401
  http_redirect_https:
    prober: http
    timeout: 5s
    http:
      preferred_ip_protocol: ip4
      follow_redirects: false
      valid_status_codes:
        - 301
        - 302
        - 307
        - 308
      fail_if_header_not_matches:
        - header: Location
          regexp: '^https://'
`

{% for site in observability_web_sites %}
{% set site_id = site.root_name | regex_replace('[^A-Za-z0-9_]', '_') %}
  target {
    name    = {{ (site_id ~ "_apex_200") | to_json }}
    address = {{ ("https://" ~ site.domain ~ "/") | to_json }}
    module  = "http_2xx_skip_tls_verify"
    labels  = {
      check       = "https_200",
      client      = {{ observability_client | to_json }},
      domain      = {{ site.domain | to_json }},
      environment = {{ grayhaven_environment | to_json }},
      host        = {{ inventory_hostname | to_json }},
      project     = {{ observability_project | to_json }},
      role        = {{ observability_role | to_json }},
    }
  }

  target {
    name    = {{ (site_id ~ "_www_200") | to_json }}
    address = {{ ("https://" ~ site.aliases[0] ~ "/") | to_json }}
    module  = "http_2xx_skip_tls_verify"
    labels  = {
      check       = "https_200",
      client      = {{ observability_client | to_json }},
      domain      = {{ site.aliases[0] | to_json }},
      environment = {{ grayhaven_environment | to_json }},
      host        = {{ inventory_hostname | to_json }},
      project     = {{ observability_project | to_json }},
      role        = {{ observability_role | to_json }},
    }
  }

  target {
    name    = {{ (site_id ~ "_dev_401") | to_json }}
    address = {{ ("https://" ~ site.dev_domain ~ "/") | to_json }}
    module  = "http_401_skip_tls_verify"
    labels  = {
      check       = "dev_basic_auth_401",
      client      = {{ observability_client | to_json }},
      domain      = {{ site.dev_domain | to_json }},
      environment = {{ grayhaven_environment | to_json }},
      host        = {{ inventory_hostname | to_json }},
      project     = {{ observability_project | to_json }},
      role        = {{ observability_role | to_json }},
    }
  }

  target {
    name    = {{ (site_id ~ "_cert") | to_json }}
    address = {{ ("https://" ~ site.domain ~ "/") | to_json }}
    module  = "http_2xx_skip_tls_verify"
    labels  = {
      check       = "ssl_certificate",
      client      = {{ observability_client | to_json }},
      domain      = {{ site.domain | to_json }},
      environment = {{ grayhaven_environment | to_json }},
      host        = {{ inventory_hostname | to_json }},
      project     = {{ observability_project | to_json }},
      role        = {{ observability_role | to_json }},
    }
  }

  target {
    name    = {{ (site_id ~ "_cert_trust") | to_json }}
    address = {{ ("https://" ~ site.domain ~ "/") | to_json }}
    module  = "http_2xx"
    labels  = {
      check       = "ssl_certificate_trusted",
      client      = {{ observability_client | to_json }},
      domain      = {{ site.domain | to_json }},
      environment = {{ grayhaven_environment | to_json }},
      host        = {{ inventory_hostname | to_json }},
      project     = {{ observability_project | to_json }},
      role        = {{ observability_role | to_json }},
    }
  }

{% for redirect_domain in [site.domain, site.aliases[0], site.dev_domain] %}
  target {
    name    = {{ (site_id ~ "_redirect_" ~ loop.index) | to_json }}
    address = {{ ("http://" ~ redirect_domain ~ "/") | to_json }}
    module  = "http_redirect_https"
    labels  = {
      check       = "http_https_redirect",
      client      = {{ observability_client | to_json }},
      domain      = {{ redirect_domain | to_json }},
      environment = {{ grayhaven_environment | to_json }},
      host        = {{ inventory_hostname | to_json }},
      project     = {{ observability_project | to_json }},
      role        = {{ observability_role | to_json }},
    }
  }

{% endfor %}
{% endfor %}
}

prometheus.scrape "blackbox" {
  targets         = prometheus.exporter.blackbox.http.targets
  scrape_interval = "60s"
  forward_to      = [prometheus.relabel.grayhaven.receiver]
}
{% endif %}

prometheus.relabel "grayhaven" {
  forward_to = [prometheus.remote_write.grafana.receiver]

  rule {
    source_labels = ["client"]
    regex         = "^$"
    target_label = "client"
    replacement  = {{ observability_client | to_json }}
  }

  rule {
    source_labels = ["environment"]
    regex         = "^$"
    target_label = "environment"
    replacement  = {{ grayhaven_environment | to_json }}
  }

  rule {
    source_labels = ["host"]
    regex         = "^$"
    target_label = "host"
    replacement  = {{ inventory_hostname | to_json }}
  }

  rule {
    source_labels = ["project"]
    regex         = "^$"
    target_label = "project"
    replacement  = {{ observability_project | to_json }}
  }

  rule {
    source_labels = ["role"]
    regex         = "^$"
    target_label = "role"
    replacement  = {{ observability_role | to_json }}
  }

  rule {
    target_label = "configured_by"
    replacement  = "ansible"
  }
}

prometheus.remote_write "grafana" {
  endpoint {
    url = {{ observability_grafana_credentials.prometheus.remote_write_url | to_json }}

    basic_auth {
      username      = {{ observability_grafana_credentials.prometheus.username | string | to_json }}
      password_file = {{ observability_alloy_token_file | to_json }}
    }
  }
}

{% if observability_logs_enabled %}
{% for site in observability_web_sites %}
{% set site_id = site.root_name | regex_replace('[^A-Za-z0-9_]', '_') %}
{% for log_name in ['prod.access', 'prod.error', 'dev.access', 'dev.error'] %}
local.file_match "nginx_{{ site_id }}_{{ log_name | regex_replace('[^A-Za-z0-9_]', '_') }}" {
  path_targets = [{
    "__path__"   = {{ ("/var/log/nginx/" ~ site.root_name ~ "." ~ log_name ~ ".log") | to_json }},
    "client"     = {{ observability_client | to_json }},
    "domain"     = {{ site.domain | to_json }},
    "environment" = {{ grayhaven_environment | to_json }},
    "host"       = {{ inventory_hostname | to_json }},
    "job"        = "nginx_{{ 'access' if 'access' in log_name else 'error' }}",
    "project"    = {{ observability_project | to_json }},
    "role"       = {{ observability_role | to_json }},
    "site"       = "{{ 'dev' if log_name.startswith('dev') else 'prod' }}",
  }]
}

loki.source.file "nginx_{{ site_id }}_{{ log_name | regex_replace('[^A-Za-z0-9_]', '_') }}" {
  targets    = local.file_match.nginx_{{ site_id }}_{{ log_name | regex_replace('[^A-Za-z0-9_]', '_') }}.targets
  forward_to = [loki.process.grayhaven_raw.receiver]
}

{% endfor %}
{% endfor %}
local.file_match "audit" {
  path_targets = [{
    "__path__"   = "/var/log/audit/audit.log",
    "client"     = {{ observability_client | to_json }},
    "environment" = {{ grayhaven_environment | to_json }},
    "host"       = {{ inventory_hostname | to_json }},
    "job"        = "audit",
    "project"    = {{ observability_project | to_json }},
    "role"       = {{ observability_role | to_json }},
  }]
}

loki.source.file "audit" {
  targets    = local.file_match.audit.targets
  forward_to = [
    loki.process.grayhaven_raw.receiver,
    loki.process.grayhaven_dashboard_auth.receiver,
    loki.process.grayhaven_dashboard_selinux.receiver,
  ]
}

local.file_match "certbot" {
  path_targets = [{
    "__path__"   = "/var/log/letsencrypt/letsencrypt.log",
    "client"     = {{ observability_client | to_json }},
    "environment" = {{ grayhaven_environment | to_json }},
    "host"       = {{ inventory_hostname | to_json }},
    "job"        = "certbot",
    "project"    = {{ observability_project | to_json }},
    "role"       = {{ observability_role | to_json }},
  }]
}

loki.source.file "certbot" {
  targets    = local.file_match.certbot.targets
  forward_to = [loki.process.grayhaven_raw.receiver]
}

{% if observability_role == "bastion" %}
local.file_match "ansible_runner_dashboard" {
  path_targets = [{
    "__path__"   = "/var/lib/grayhaven/observability/ansible-runner-dashboard.log",
    "client"     = {{ observability_client | to_json }},
    "environment" = {{ grayhaven_environment | to_json }},
    "host"       = {{ inventory_hostname | to_json }},
    "job"        = "ansible_runner_dashboard",
    "project"    = {{ observability_project | to_json }},
    "role"       = {{ observability_role | to_json }},
  }]
}

loki.source.file "ansible_runner_dashboard" {
  targets    = local.file_match.ansible_runner_dashboard.targets
  forward_to = [loki.process.grayhaven_dashboard_runner.receiver]
}

{% endif %}
loki.relabel "journal_dashboard" {
  forward_to = []

  rule {
    source_labels = ["__journal__systemd_unit"]
    target_label  = "systemd_unit"
  }

  rule {
    source_labels = ["__journal_syslog_identifier"]
    target_label  = "syslog_identifier"
  }

  rule {
    source_labels = ["__journal_priority_keyword"]
    target_label  = "journal_priority"
  }
}

loki.source.journal "system" {
  max_age    = "24h"
  labels     = {
    "client"      = {{ observability_client | to_json }},
    "environment" = {{ grayhaven_environment | to_json }},
    "host"        = {{ inventory_hostname | to_json }},
    "job"         = "systemd_journal",
    "project"     = {{ observability_project | to_json }},
    "role"        = {{ observability_role | to_json }},
  }
  forward_to = [loki.process.grayhaven_raw.receiver]
}

loki.source.journal "system_dashboard" {
  max_age       = "24h"
  relabel_rules = loki.relabel.journal_dashboard.rules
  labels        = {
    "client"      = {{ observability_client | to_json }},
    "environment" = {{ grayhaven_environment | to_json }},
    "host"        = {{ inventory_hostname | to_json }},
    "job"         = "systemd_journal",
    "project"     = {{ observability_project | to_json }},
    "role"        = {{ observability_role | to_json }},
  }
  forward_to = [
    loki.process.grayhaven_dashboard_auth.receiver,
    loki.process.grayhaven_dashboard_superuser.receiver,
    loki.process.grayhaven_dashboard_fail2ban.receiver,
    loki.process.grayhaven_dashboard_system_errors.receiver,
  ]
}

loki.process "grayhaven_raw" {
  stage.drop {
    expression = ".*cloud-init.*"
  }

  forward_to = [loki.process.grayhaven_redact.receiver]
}

loki.process "grayhaven_dashboard_runner" {
  stage.logfmt {
    mapping = {
      "line"        = "",
      "observed_at" = "",
      "ordered_at"  = "",
      "run_id"      = "",
      "sequence"    = "",
    }
  }

  stage.timestamp {
    source = "ordered_at"
    format = "RFC3339Nano"
  }

  stage.structured_metadata {
    values = {
      "observed_at" = "",
      "run_id"      = "",
      "sequence"    = "",
    }
  }

  stage.output {
    source = "line"
  }

  stage.static_labels {
    values = {
      grayhaven_log_ansible_runner = "true",
      grayhaven_log_host           = {{ observability_short_hostname | to_json }},
      grayhaven_log_view           = "dashboard",
    }
  }

  forward_to = [loki.process.grayhaven_redact.receiver]
}

loki.process "grayhaven_dashboard_fail2ban" {
  stage.match {
    selector = `{systemd_unit!="fail2ban.service"}`
    action   = "drop"
  }

  stage.static_labels {
    values = {
      grayhaven_log_fail2ban = "true",
      grayhaven_log_host     = {{ observability_short_hostname | to_json }},
      grayhaven_log_view     = "dashboard",
    }
  }

  forward_to = [loki.process.grayhaven_redact.receiver]
}

loki.process "grayhaven_dashboard_superuser" {
  stage.drop {
    expression = ".*ansible-ansible\\.[^ ]+ Invoked with.*"
  }

  stage.drop {
    expression = ".*user=\"ansible\".*grayhaven-root-command.*"
  }

  stage.static_labels {
    values = {
      grayhaven_log_host            = {{ observability_short_hostname | to_json }},
      grayhaven_log_superuser_audit = "false",
      grayhaven_log_view            = "dashboard",
    }
  }

  stage.match {
    selector = `{syslog_identifier="sudo"} |= " ; COMMAND=" != " ansible :" != "a password is required" != "incorrect password attempts" != "incorrect password attempt" != "conversation failed" != "auth could not identify password"`

    stage.static_labels {
      values = {
        grayhaven_log_superuser_audit = "true",
      }
    }
  }

  stage.match {
    selector = `{job="systemd_journal"} |= "grayhaven-root-command"`

    stage.static_labels {
      values = {
        grayhaven_log_superuser_audit = "true",
      }
    }
  }

  stage.match {
    selector = `{grayhaven_log_superuser_audit!="true"}`
    action   = "drop"
  }

  forward_to = [loki.process.grayhaven_redact.receiver]
}

loki.process "grayhaven_dashboard_auth" {
  stage.static_labels {
    values = {
      grayhaven_log_authentication        = "false",
      grayhaven_log_authentication_result = "unknown",
      grayhaven_log_host                  = {{ observability_short_hostname | to_json }},
      grayhaven_log_view                  = "dashboard",
    }
  }

  stage.match {
    selector = `{job="audit"} |= "type=USER_LOGIN" |= "acct="`

    stage.regex {
      expression = ".*acct=\"?(?P<auth_user>[^\" ]+)\"?.*addr=(?P<auth_addr>[^ ?][^ ]*).*res=(?P<auth_result>success|failed).*"
    }

    stage.template {
      source   = "grayhaven_dashboard_line"
      template = {% raw %}"{{ if eq .auth_result \"success\" }}User {{ .auth_user }} logged in{{ else }}Failed login for user {{ .auth_user }}{{ end }}{{ if and .auth_addr (ne .auth_addr \"?\") }} from {{ .auth_addr }}{{ end }}"{% endraw %}
    }

    stage.labels {
      values = {
        grayhaven_log_authentication_result = "auth_result",
      }
    }

    stage.output {
      source = "grayhaven_dashboard_line"
    }

    stage.static_labels {
      values = {
        grayhaven_log_authentication = "true",
      }
    }
  }

  stage.match {
    selector = `{job="audit"} |= "type=USER_LOGIN" |= " id="`

    stage.regex {
      expression = ".* id=[^ ]+ .*addr=(?P<auth_addr>[^ ?][^ ]*).*res=(?P<auth_result>success|failed).*ID=\"(?P<auth_user>[^\"]+)\".*"
    }

    stage.template {
      source   = "grayhaven_dashboard_line"
      template = {% raw %}"{{ if eq .auth_result \"success\" }}User {{ .auth_user }} logged in{{ else }}Failed login for user {{ .auth_user }}{{ end }}{{ if and .auth_addr (ne .auth_addr \"?\") }} from {{ .auth_addr }}{{ end }}"{% endraw %}
    }

    stage.labels {
      values = {
        grayhaven_log_authentication_result = "auth_result",
      }
    }

    stage.output {
      source = "grayhaven_dashboard_line"
    }

    stage.static_labels {
      values = {
        grayhaven_log_authentication = "true",
      }
    }
  }

  stage.match {
    selector = `{job="audit"} |= "type=USER_LOGOUT" |= "acct="`

    stage.regex {
      expression = ".*acct=\"?(?P<auth_user>[^\" ]+)\"?.*"
    }

    stage.template {
      source   = "grayhaven_dashboard_line"
      template = {% raw %}"User {{ .auth_user }} logged out"{% endraw %}
    }

    stage.output {
      source = "grayhaven_dashboard_line"
    }

    stage.static_labels {
      values = {
        grayhaven_log_authentication        = "true",
        grayhaven_log_authentication_result = "success",
      }
    }
  }

  stage.match {
    selector = `{job="audit"} |= "type=USER_LOGOUT" |= " id="`

    stage.regex {
      expression = ".* id=[^ ]+ .*ID=\"(?P<auth_user>[^\"]+)\".*"
    }

    stage.template {
      source   = "grayhaven_dashboard_line"
      template = {% raw %}"User {{ .auth_user }} logged out"{% endraw %}
    }

    stage.output {
      source = "grayhaven_dashboard_line"
    }

    stage.static_labels {
      values = {
        grayhaven_log_authentication        = "true",
        grayhaven_log_authentication_result = "success",
      }
    }
  }

  stage.match {
    selector = `{syslog_identifier="sudo"} |= " ; COMMAND=" != " ansible :" != "a password is required" != "incorrect password attempts" != "conversation failed" != "auth could not identify password"`

    stage.regex {
      expression = ".*sudo\\[[0-9]+\\]:\\s+(?P<auth_user>[^\\s:]+)\\s+:.*"
    }

    stage.template {
      source   = "grayhaven_dashboard_line"
      template = {% raw %}"User {{ .auth_user }} used sudo"{% endraw %}
    }

    stage.output {
      source = "grayhaven_dashboard_line"
    }

    stage.static_labels {
      values = {
        grayhaven_log_authentication        = "true",
        grayhaven_log_authentication_result = "failed",
      }
    }
  }

  stage.match {
    selector = `{syslog_identifier="sudo"} |= "auth could not identify password for ["`

    stage.regex {
      expression = ".*auth could not identify password for \\[(?P<auth_user>[^\\]]+)\\].*"
    }

    stage.template {
      source   = "grayhaven_dashboard_line"
      template = {% raw %}"User {{ .auth_user }} failed to use sudo"{% endraw %}
    }

    stage.output {
      source = "grayhaven_dashboard_line"
    }

    stage.static_labels {
      values = {
        grayhaven_log_authentication        = "true",
        grayhaven_log_authentication_result = "failed",
      }
    }
  }

  stage.match {
    selector = `{syslog_identifier="sudo"} |= "a password is required"`

    stage.regex {
      expression = ".*sudo\\[[0-9]+\\]:\\s+(?P<auth_user>[^\\s:]+)\\s+:.*"
    }

    stage.template {
      source   = "grayhaven_dashboard_line"
      template = {% raw %}"User {{ .auth_user }} failed to use sudo"{% endraw %}
    }

    stage.output {
      source = "grayhaven_dashboard_line"
    }

    stage.static_labels {
      values = {
        grayhaven_log_authentication        = "true",
        grayhaven_log_authentication_result = "failed",
      }
    }
  }

  stage.match {
    selector = `{syslog_identifier="sudo"} |= "incorrect password attempts"`

    stage.regex {
      expression = ".*sudo\\[[0-9]+\\]:\\s+(?P<auth_user>[^\\s:]+)\\s+:.*"
    }

    stage.template {
      source   = "grayhaven_dashboard_line"
      template = {% raw %}"User {{ .auth_user }} failed to use sudo"{% endraw %}
    }

    stage.output {
      source = "grayhaven_dashboard_line"
    }

    stage.static_labels {
      values = {
        grayhaven_log_authentication        = "true",
        grayhaven_log_authentication_result = "success",
      }
    }
  }

  stage.match {
    selector = `{syslog_identifier=~"su|su-l"} |~ "session opened for user"`

    stage.regex {
      expression = ".*session opened for user (?P<target_user>[^\\(]+).* by (?P<auth_user>[^\\(]+).*"
    }

    stage.template {
      source   = "grayhaven_dashboard_line"
      template = {% raw %}"User {{ .auth_user }} used su to become {{ .target_user }}"{% endraw %}
    }

    stage.output {
      source = "grayhaven_dashboard_line"
    }

    stage.static_labels {
      values = {
        grayhaven_log_authentication        = "true",
        grayhaven_log_authentication_result = "failed",
      }
    }
  }

  stage.match {
    selector = `{syslog_identifier=~"su|su-l"} |= "authentication failure"`

    stage.regex {
      expression = ".*ruser=(?P<auth_user>\\S+).*user=(?P<target_user>\\S+).*"
    }

    stage.template {
      source   = "grayhaven_dashboard_line"
      template = {% raw %}"User {{ .auth_user }} failed to use su to become {{ .target_user }}"{% endraw %}
    }

    stage.output {
      source = "grayhaven_dashboard_line"
    }

    stage.static_labels {
      values = {
        grayhaven_log_authentication = "true",
      }
    }
  }

  stage.match {
    selector = `{grayhaven_log_authentication!="true"}`
    action   = "drop"
  }

  stage.drop {
    expression = ".*<no value>.*"
  }

  forward_to = [loki.process.grayhaven_redact.receiver]
}

loki.process "grayhaven_dashboard_selinux" {
  stage.match {
    selector = `{job="audit"} !~ "type=(AVC|USER_AVC|SELINUX_ERR)"`
    action   = "drop"
  }

  stage.static_labels {
    values = {
      grayhaven_log_selinux_avc = "true",
      grayhaven_log_host        = {{ observability_short_hostname | to_json }},
      grayhaven_log_view        = "dashboard",
    }
  }

  forward_to = [loki.process.grayhaven_redact.receiver]
}

loki.process "grayhaven_dashboard_system_errors" {
  stage.drop {
    expression = ".*service=remotecfg.*err=\"noop client\".*"
  }

  stage.match {
    selector = `{systemd_unit="grayhaven-ansible-runner.service"}`
    action   = "drop"
  }

  stage.match {
    selector = `{systemd_unit="fail2ban.service"}`
    action   = "drop"
  }

  stage.drop {
    expression = ".*SELinux is preventing.*"
  }

  stage.drop {
    expression = ".*type=(AVC|USER_AVC|SELINUX_ERR).*"
  }

  stage.match {
    selector = `{syslog_identifier=~"sudo|su|su-l"}`
    action   = "drop"
  }

  stage.match {
    selector = `{journal_priority!~"emerg|alert|crit|error"}`
    action   = "drop"
  }

  stage.static_labels {
    values = {
      grayhaven_log_system_error = "true",
      grayhaven_log_host         = {{ observability_short_hostname | to_json }},
      grayhaven_log_view         = "dashboard",
    }
  }

  forward_to = [loki.process.grayhaven_redact.receiver]
}

loki.process "grayhaven_redact" {
  stage.replace {
    expression = "(?i)(?:password|passwd|token|secret|private_key)\\s*[:=]\\s*(\\S+)"
    replace    = "<redacted>"
  }

  forward_to = [loki.write.grafana.receiver]
}

loki.write "grafana" {
  endpoint {
    url = {{ observability_grafana_credentials.loki.push_url | to_json }}

    basic_auth {
      username      = {{ observability_grafana_credentials.loki.username | string | to_json }}
      password_file = {{ observability_alloy_token_file | to_json }}
    }
  }
}
{% endif %}
