def site_rules(config: dict[str, Any], folder_uid: str, datasource_uid: str) -> list[dict[str, Any]]:
    rules = []
    if not config["sites"]:
        return rules

    web_host = next((host for host in config["hosts"] if host["role"] == "web"), None)
    if web_host is None:
        return rules

    common = {
        "folder_uid": folder_uid,
        "rule_group": config["grafana"]["evaluation_group"],
        "datasource_uid": datasource_uid,
        "contact_point": config["grafana"]["contact_point"],
    }

    for site in config["sites"]:
        for target_domain in [site["domain"], *site["aliases"]]:
            rules.append(
                alert_rule(
                    title=f"{target_domain} HTTPS availability",
                    expression=(
                        "max by (domain, environment, role, project, client) "
                        f'(probe_success{{domain="{promql_string(target_domain)}",check="https_200"}})'
                    ),
                    evaluator_type="lt",
                    threshold=1,
                    labels=base_labels(
                        config,
                        {
                            "check": "https_200",
                            "domain": target_domain,
                            "project": web_host["project"],
                            "role": "web",
                        },
                    ),
                    annotations={
                        "summary": "HTTPS availability check failed",
                        "description": f"{target_domain} HTTPS check did not return 200 OK.",
                    },
                    **common,
                )
            )

        if site.get("dev_domain"):
            rules.append(
                alert_rule(
                    title=f"{site['dev_domain']} basic auth",
                    expression=(
                        "max by (domain, environment, role, project, client) "
                        f'(probe_success{{domain="{promql_string(site["dev_domain"])}",'
                        'check="dev_basic_auth_401"})'
                    ),
                    evaluator_type="lt",
                    threshold=1,
                    labels=base_labels(
                        config,
                        {
                            "check": "dev_basic_auth_401",
                            "domain": site["dev_domain"],
                            "project": web_host["project"],
                            "role": "web",
                        },
                    ),
                    annotations={
                        "summary": "Development basic auth check failed",
                        "description": (
                            f"{site['dev_domain']} did not return 401 Unauthorized "
                            "without credentials."
                        ),
                    },
                    **common,
                )
            )

        redirect_domains = [site["domain"], *site["aliases"]]
        if site.get("dev_domain"):
            redirect_domains.append(site["dev_domain"])
        rules.append(
            alert_rule(
                title=f"{site['domain']} HTTP to HTTPS redirects",
                expression=(
                    "min by (domain, environment, role, project, client) "
                    f'(probe_success{{domain=~"{domain_regex(redirect_domains)}",'
                    'check="http_https_redirect"})'
                ),
                evaluator_type="lt",
                threshold=1,
                labels=base_labels(
                    config,
                    {
                        "check": "http_https_redirect",
                        "domain": site["domain"],
                        "project": web_host["project"],
                        "role": "web",
                    },
                ),
                annotations={
                    "summary": "HTTP to HTTPS redirect check failed",
                    "description": (
                        f"{site['domain']} HTTP to HTTPS redirect checks did not all return "
                        "a valid HTTPS redirect."
                    ),
                },
                **common,
            )
        )

        if config.get("tls_mode") == "host":
            rules.append(
                alert_rule(
                    title=f"{site['domain']} SSL certificate expired",
                    expression=(
                        "max by (domain, environment, role, project, client) "
                        f'(probe_ssl_earliest_cert_expiry{{domain="{promql_string(site["domain"])}",'
                        'check="ssl_certificate"} - time())'
                    ),
                    evaluator_type="lt",
                    threshold=0,
                    labels=base_labels(
                        config,
                        {
                            "check": "ssl_certificate_expired",
                            "domain": site["domain"],
                            "project": web_host["project"],
                            "role": "web",
                        },
                    ),
                    annotations={
                        "summary": "SSL certificate is expired",
                        "description": f"{site['domain']} SSL certificate is expired.",
                    },
                    **common,
                )
            )
            rules.append(
                alert_rule(
                    title=f"{site['domain']} SSL certificate expiring within 14 days",
                    expression=(
                        "max by (domain, environment, role, project, client) "
                        "("
                        f'(probe_ssl_earliest_cert_expiry{{domain="{promql_string(site["domain"])}",'
                        'check="ssl_certificate"} - time() '
                        f'< {float(config["thresholds"]["certificate_expiring_seconds"])}) '
                        "and "
                        f'(probe_ssl_earliest_cert_expiry{{domain="{promql_string(site["domain"])}",'
                        'check="ssl_certificate"} - time() > 0)'
                        ")"
                    ),
                    evaluator_type="gt",
                    threshold=0,
                    labels=base_labels(
                        config,
                        {
                            "check": "ssl_certificate_expiring",
                            "domain": site["domain"],
                            "project": web_host["project"],
                            "role": "web",
                        },
                    ),
                    annotations={
                        "summary": "SSL certificate is expiring soon",
                        "description": f"{site['domain']} SSL certificate expires within 14 days.",
                        "check_value": "{{ humanizeDuration $values.A.Value }}",
                    },
                    **common,
                )
            )
            rules.append(
                alert_rule(
                    title=f"{site['domain']} using untrusted SSL certificate",
                    expression=(
                        "max by (domain, environment, role, project, client) "
                        f'(probe_success{{domain="{promql_string(site["domain"])}",'
                        'check="ssl_certificate_trusted"})'
                    ),
                    evaluator_type="lt",
                    threshold=1,
                    labels=base_labels(
                        config,
                        {
                            "check": "ssl_certificate_trusted",
                            "domain": site["domain"],
                            "project": web_host["project"],
                            "role": "web",
                        },
                    ),
                    annotations={
                        "summary": "SSL certificate is not publicly trusted",
                        "description": (
                            f"{site['domain']} is presenting an SSL certificate "
                            "that the external probe does not trust."
                        ),
                    },
                    **common,
                )
            )

    return rules


def external_service_rules(config: dict[str, Any], folder_uid: str, datasource_uid: str) -> list[dict[str, Any]]:
    common = {
        "folder_uid": folder_uid,
        "rule_group": config["grafana"]["evaluation_group"],
        "datasource_uid": datasource_uid,
        "contact_point": config["grafana"]["contact_point"],
    }
    selector = (
        f'client="{promql_string(config["labels"]["client"])}",'
        f'environment="{promql_string(config["labels"]["environment"])}"'
    )

    rules = [
        alert_rule(
            title="GCS service telemetry failed for >= 5 min",
            expression=(
                "max by (client, environment, location, project_id) "
                f"(grayhaven_gcs_service_telemetry_success{{{selector}}})"
