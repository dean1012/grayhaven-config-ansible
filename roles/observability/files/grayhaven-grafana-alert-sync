            },
            **common,
        ),
    ]

    rules.append(
        alert_rule(
            title="Proton status telemetry failed for >= 5 min",
            expression=(
                "max by (client, environment, provider) "
                f"(grayhaven_proton_telemetry_success{{{selector}}})"
            ),
            evaluator_type="lt",
            threshold=1,
            duration="5m",
            labels=base_labels(
                config,
                {
                    "check": "proton_telemetry_success",
                    "service": "Proton",
