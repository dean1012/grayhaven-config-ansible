            ),
            annotations={
                "summary": "Proton status telemetry collection failed",
                "description": "The Proton public service-health collector is not reporting successful telemetry.",
            },
            no_data_state="Alerting",
            **common,
        )
    )

    for service_name, component_name in PROTON_SERVICES:
        rules.append(
            alert_rule(
                title=f"Proton {service_name} Degraded for >= 5 min",
                expression=(
                    "max by (client, environment, provider, service, component, status) "
                    f"(grayhaven_proton_service_status{{{selector},"
                    f'service="{promql_string(service_name)}",'
                    f'component="{promql_string(component_name)}"}})'
