                config,
                {
                    "check": "gcs_service_telemetry_success",
                    "service": "Google Cloud Storage",
                },
            ),
            annotations={
                "summary": "GCS service telemetry collection failed",
                "description": "The Google Cloud Storage public service-health collector is not reporting successful telemetry.",
            },
            no_data_state="Alerting",
            **common,
        ),
        alert_rule(
            title="GCS Degraded for >= 5 min",
            expression=(
                "max by (client, environment, location, product, project_id, status) "
