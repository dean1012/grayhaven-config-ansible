                    "description": f"{component_name} is not reporting Operational status.",
                    "service_status": "{{ $labels.status }}",
                },
                **common,
            )
        )

    return rules


def desired_rules(config: dict[str, Any], folder_uid: str, datasource_uid: str) -> dict[str, dict[str, Any]]:
    rules = []
    rules.extend(host_metric_rules(config, folder_uid, datasource_uid))
    rules.extend(service_rules(config, folder_uid, datasource_uid))
    rules.extend(site_rules(config, folder_uid, datasource_uid))
    rules.extend(external_service_rules(config, folder_uid, datasource_uid))
    return {rule["uid"]: rule for rule in rules}


def comparable(rule: dict[str, Any]) -> dict[str, Any]:
    keys = [
        "uid",
        "title",
        "folderUID",
        "ruleGroup",
        "condition",
        "data",
        "noDataState",
        "execErrState",
        "for",
        "annotations",
        "labels",
        "isPaused",
        "notification_settings",
    ]
    return {key: rule.get(key) for key in keys}


def is_managed(rule: dict[str, Any], client: str) -> bool:
    labels = rule.get("labels", {})
    return labels.get(MANAGED_LABEL) == MANAGED_VALUE and labels.get("client") == client


def timestamp(value: datetime) -> str:
    return value.isoformat(timespec="milliseconds").replace("+00:00", "Z")


def create_initial_silence(config: dict[str, Any], duration_minutes: int) -> str:
    if duration_minutes < 1:
        raise GrafanaError("initial silence duration must be at least one minute")

    client = GrafanaClient(config["grafana"]["stack_url"], config["grafana"]["api_token"])
    labels = config["labels"]
    now = datetime.now(timezone.utc)
    payload = {
        "matchers": [
            {
                "name": MANAGED_LABEL,
                "value": MANAGED_VALUE,
                "isRegex": False,
                "isEqual": True,
            },
            {
                "name": "client",
                "value": labels["client"],
                "isRegex": False,
                "isEqual": True,
            },
            {
                "name": "environment",
                "value": labels["environment"],
                "isRegex": False,
                "isEqual": True,
            },
        ],
        "startsAt": timestamp(now),
        "endsAt": timestamp(now + timedelta(minutes=duration_minutes)),
        "createdBy": INITIAL_SILENCE_CREATED_BY,
        "comment": INITIAL_SILENCE_COMMENT,
    }
    return client.create_silence(payload)


def sync(config: dict[str, Any]) -> tuple[int, int, int]:
    client = GrafanaClient(config["grafana"]["stack_url"], config["grafana"]["api_token"])
    datasource_uid = client.datasource_uid(config["grafana"]["prometheus_datasource_name"])
    folder_uid = client.folder_uid(config["grafana"]["folder"])
    desired = desired_rules(config, folder_uid, datasource_uid)
    existing = {
        rule["uid"]: rule
        for rule in client.alert_rules()
        if is_managed(rule, config["labels"]["client"])
    }

    created = 0
    updated = 0
    deleted = 0

    for uid, rule in desired.items():
        if uid not in existing:
            client.create_rule(rule)
            created += 1
            continue

        if comparable(existing[uid]) != comparable(rule):
            client.update_rule(uid, rule)
            updated += 1

    for uid in sorted(set(existing) - set(desired)):
        client.delete_rule(uid)
        deleted += 1

    if desired:
        interval_seconds = duration_seconds(config["grafana"]["evaluation_interval"])
        if client.update_rule_group_interval(folder_uid, config["grafana"]["evaluation_group"], interval_seconds):
            updated += 1

    return created, updated, deleted


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--config", required=True, help="Path to Grafana alert sync JSON configuration")
    parser.add_argument(
        "--create-initial-silence",
        action="store_true",
        help="Create the initial convergence silence and exit without syncing alert rules",
    )
    parser.add_argument(
        "--silence-minutes",
        type=int,
        default=15,
        help="Initial convergence silence duration in minutes",
    )
    args = parser.parse_args()

    with open(args.config, encoding="utf-8") as config_file:
        config = json.load(config_file)

    if args.create_initial_silence:
        silence_id = create_initial_silence(config, args.silence_minutes)
        print(f"changed=true silence_id={silence_id}")
        return 0

    created, updated, deleted = sync(config)
    changed = created + updated + deleted > 0
    print(f"changed={str(changed).lower()} created={created} updated={updated} deleted={deleted}")
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except GrafanaError as error:
        print(f"error: {error}", file=sys.stderr)
        raise SystemExit(1)
