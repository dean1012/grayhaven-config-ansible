#!/usr/bin/env python3
"""Publish sanitized Grafana IRM alert-group state as textfile metrics."""

from __future__ import annotations

import argparse
import datetime
import json
import os
import pathlib
import sys
import tempfile
import time
import urllib.error
import urllib.parse
import urllib.request
from typing import Any
from zoneinfo import ZoneInfo

DEFAULT_CONFIG_PATH = pathlib.Path("/etc/grayhaven/observability/irm-alert-groups.json")
DEFAULT_STATES = ("new", "acknowledged", "silenced")
DISPLAY_TIMEZONE = ZoneInfo("America/Chicago")
STATE_SORT_ORDER = {
    "firing": "0",
    "new": "0",
    "acknowledged": "1",
    "silenced": "2",
}
STATE_DISPLAY_NAMES = {
    "firing": "Firing",
    "new": "Firing",
    "acknowledged": "Acknowledged",
    "silenced": "Silenced",
}


class GrafanaIrmError(RuntimeError):
    """Raised when Grafana IRM cannot return usable alert-group state."""


class GrafanaIrmClient:
    """Minimal Grafana IRM API client for read-only alert-group collection."""

    def __init__(self, stack_url: str, api_token: str) -> None:
        self.stack_url = stack_url.rstrip("/")
        self.api_token = api_token
        self.oncall_api_url: str | None = None

    def _request(
        self,
        url: str,
        *,
        headers: dict[str, str] | None = None,
        expected: tuple[int, ...] = (200,),
    ) -> Any:
        request_headers = {
            "Accept": "application/json",
            "Authorization": f"Bearer {self.api_token}",
        }
        if headers:
            request_headers.update(headers)

        for attempt in range(5):
            request = urllib.request.Request(url, headers=request_headers, method="GET")
            try:
                with urllib.request.urlopen(request, timeout=30) as response:
                    status = response.getcode()
                    body = response.read().decode("utf-8")
            except urllib.error.HTTPError as error:
                if error.code == 429 or 500 <= error.code <= 599:
                    retry_after = error.headers.get("Retry-After")
                    delay = int(retry_after) if retry_after and retry_after.isdigit() else min(2**attempt, 30)
                    time.sleep(delay)
                    continue

                message = error.read().decode("utf-8", errors="replace")
                raise GrafanaIrmError(f"GET {url} failed with HTTP {error.code}: {message}") from error
            except urllib.error.URLError as error:
                if attempt < 4:
                    time.sleep(min(2**attempt, 30))
                    continue
                raise GrafanaIrmError(f"GET {url} failed: {error.reason}") from error

            if status not in expected:
                raise GrafanaIrmError(f"GET {url} returned unexpected HTTP status {status}")

            if not body:
                return None

            return json.loads(body)

        raise GrafanaIrmError(f"GET {url} exceeded retry budget")

    def discover_oncall_api_url(self) -> str:
        if self.oncall_api_url:
            return self.oncall_api_url

        settings_url = f"{self.stack_url}/api/plugins/grafana-irm-app/settings"
        settings = self._request(settings_url)
        if not isinstance(settings, dict):
            raise GrafanaIrmError("Grafana IRM settings response was not an object")

        json_data = settings.get("jsonData")
        api_url = settings.get("onCallApiUrl")
        if not isinstance(api_url, str) and isinstance(json_data, dict):
            api_url = json_data.get("onCallApiUrl")
        if not isinstance(api_url, str) or not api_url.strip():
            raise GrafanaIrmError("Grafana IRM settings did not include onCallApiUrl")

        self.oncall_api_url = api_url.rstrip("/")
        return self.oncall_api_url

    def alert_groups(self, state: str) -> list[dict[str, Any]]:
        api_url = self.discover_oncall_api_url()
        params = urllib.parse.urlencode({"state": state})
        next_url: str | None = f"{api_url}/api/v1/alert_groups/?{params}"
        return self._paged_irm_results(next_url, "Grafana IRM alert groups")

    def alert_group_detail(self, alert_group_id: str) -> dict[str, Any]:
        encoded_id = urllib.parse.quote(alert_group_id, safe="")
        detail = self._request(
            f"{self.stack_url}/api/plugins/grafana-irm-app/resources/alertgroups/{encoded_id}/?short=false"
        )
        if not isinstance(detail, dict):
            raise GrafanaIrmError(f"Grafana IRM alert group {alert_group_id} detail response was not an object")

        return detail

    def users(self) -> list[dict[str, Any]]:
        api_url = self.discover_oncall_api_url()
        return self._paged_irm_results(f"{api_url}/api/v1/users/", "Grafana IRM users")

    def org_users(self) -> list[dict[str, Any]]:
        users = self._request(f"{self.stack_url}/api/org/users")
        if not isinstance(users, list):
            raise GrafanaIrmError("Grafana organization users response was not a list")

        return [user for user in users if isinstance(user, dict)]

    def _paged_irm_results(self, next_url: str, description: str) -> list[dict[str, Any]]:
        results: list[dict[str, Any]] = []

        while next_url:
            page = self._request(
                next_url,
                headers={"Content-Type": "application/json", "X-Grafana-URL": self.stack_url},
            )
            if not isinstance(page, dict):
                raise GrafanaIrmError(f"{description} response was not an object")

            page_results = page.get("results")
            if not isinstance(page_results, list):
                raise GrafanaIrmError(f"{description} response did not include results")

            results.extend(item for item in page_results if isinstance(item, dict))
            next_value = page.get("next")
            next_url = next_value if isinstance(next_value, str) and next_value else None

        return results


class IdentityResolver:
    """Resolve Grafana IRM user IDs into operator-friendly display names."""

    def __init__(self, irm_users: list[dict[str, Any]], org_users: list[dict[str, Any]]) -> None:
        self.irm_users = {safe_string(user.get("id")): user for user in irm_users if user.get("id")}
        self.org_names = {
            safe_string(user.get("login")): safe_string(user.get("name"))
            for user in org_users
            if user.get("login")
        }

    def username(self, irm_user_id: str) -> str:
        user = self.irm_users.get(irm_user_id)
        if not user:
            return ""

        return safe_string(user.get("username"))

    def display_name(self, irm_user_id: str) -> str:
        username = self.username(irm_user_id)
        if not username:
            return ""

        return self.org_names.get(username) or username


def label_value(value: object) -> str:
    return str(value).replace("\\", "\\\\").replace('"', '\\"').replace("\n", "\\n")


def labels(values: dict[str, object]) -> str:
    rendered = ",".join(f'{key}="{label_value(value)}"' for key, value in sorted(values.items()))
    return f"{{{rendered}}}"


def metric_line(name: str, metric_labels: dict[str, object], value: object) -> str:
    return f"{name}{labels(metric_labels)} {value}"


def safe_string(value: object, *, max_length: int = 160) -> str:
    if value is None:
        return ""

    text = str(value).replace("\r", " ").replace("\n", " ").strip()
    if len(text) <= max_length:
        return text

    return f"{text[: max_length - 3]}..."


def group_label(group: dict[str, Any], key: str) -> str:
    return safe_string(group.get(key))


def alert_group_url(group: dict[str, Any]) -> str:
    permalinks = group.get("permalinks")
    if not isinstance(permalinks, dict):
        return ""

    return safe_string(permalinks.get("web"), max_length=512)


def local_timestamp(timestamp: str) -> str:
    if not timestamp:
        return ""

    try:
        parsed = timestamp.replace("Z", "+00:00")
        local_time = datetime.datetime.fromisoformat(parsed).astimezone(DISPLAY_TIMEZONE)
    except ValueError:
        return ""

    hour = local_time.strftime("%I").lstrip("0") or "0"
    return f"{local_time:%Y-%m-%d} {hour}:{local_time:%M %p %Z}"


def state_sort_key(state: str) -> str:
    return STATE_SORT_ORDER.get(state, "9")


def state_display_name(state: str) -> str:
    return STATE_DISPLAY_NAMES.get(state, state.title())


def detail_user_display(user: object, identities: IdentityResolver) -> str:
    if not isinstance(user, dict):
        return ""

    username = safe_string(user.get("username"))
    if username:
        return identities.org_names.get(username) or username

    pk = safe_string(user.get("pk"))
    if pk:
        return identities.display_name(pk)

    return ""


def render(
    config: dict[str, Any],
    groups_by_state: dict[str, list[dict[str, Any]]],
    identities: IdentityResolver,
    details_by_id: dict[str, dict[str, Any]],
) -> str:
    metric_labels = {
        "client": config["labels"]["client"],
        "environment": config["labels"]["environment"],
    }
    output = [
        "# HELP grayhaven_irm_alert_groups_active Active Grafana IRM alert groups by state.",
        "# TYPE grayhaven_irm_alert_groups_active gauge",
    ]

    for state in DEFAULT_STATES:
        state_groups = groups_by_state.get(state, [])
        output.append(metric_line("grayhaven_irm_alert_groups_active", {**metric_labels, "state": state}, len(state_groups)))

    output.extend(
        [
            "# HELP grayhaven_irm_alert_group_info Sanitized active Grafana IRM alert-group metadata.",
            "# TYPE grayhaven_irm_alert_group_info gauge",
        ]
    )

    for state in DEFAULT_STATES:
        for group in groups_by_state.get(state, []):
            alert_group_id = group_label(group, "id")
            if not alert_group_id:
                continue

            detail = details_by_id.get(alert_group_id, {})
            state_label = group_label(group, "state") or state
            acknowledged_by = group_label(group, "acknowledged_by")
            user_display = ""
            silenced_until = ""
            if state_label == "acknowledged":
                user_display = (
                    detail_user_display(detail.get("acknowledged_by_user"), identities)
                    or identities.display_name(acknowledged_by)
                )
            elif state_label == "silenced":
                user_display = detail_user_display(detail.get("silenced_by_user"), identities)
                silenced_until = group_label(detail, "silenced_until")

            group_labels = {
                **metric_labels,
                "acknowledged_by": acknowledged_by,
                "acknowledged_by_display": identities.display_name(acknowledged_by),
                "acknowledged_by_username": identities.username(acknowledged_by),
                "alert_group_id": alert_group_id,
                "alert_group_number": group_label(group, "alert_group_number"),
                "alert_group_url": alert_group_url(group),
                "created_at": group_label(group, "created_at"),
                "created_at_display": local_timestamp(group_label(group, "created_at")),
                "silenced_until": silenced_until,
                "silenced_until_display": local_timestamp(silenced_until),
                "state": state_label,
                "state_display": state_display_name(state_label),
                "state_sort": state_sort_key(state_label),
                "title": group_label(group, "title"),
                "user_display": user_display,
            }
            output.append(metric_line("grayhaven_irm_alert_group_info", group_labels, 1))

    return "\n".join(output) + "\n"


def atomic_write(path: pathlib.Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp_name = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as tmp_file:
            tmp_file.write(content)
        os.chmod(tmp_name, 0o644)
        os.replace(tmp_name, path)
    finally:
        if os.path.exists(tmp_name):
            os.unlink(tmp_name)


def collect(
    config: dict[str, Any],
) -> tuple[dict[str, list[dict[str, Any]]], IdentityResolver, dict[str, dict[str, Any]]]:
    client = GrafanaIrmClient(config["grafana"]["stack_url"], config["grafana"]["api_token"])
    groups_by_state = {state: client.alert_groups(state) for state in DEFAULT_STATES}
    identities = IdentityResolver(client.users(), client.org_users())
    details_by_id = {}
    for groups in groups_by_state.values():
        for group in groups:
            alert_group_id = group_label(group, "id")
            if alert_group_id:
                details_by_id[alert_group_id] = client.alert_group_detail(alert_group_id)

    return groups_by_state, identities, details_by_id


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Publish Grafana IRM alert-group state as textfile metrics.")
    parser.add_argument("--config", type=pathlib.Path, default=DEFAULT_CONFIG_PATH)
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    with args.config.open(encoding="utf-8") as config_file:
        config = json.load(config_file)

    output_path = pathlib.Path(config["output_path"])
    groups_by_state, identities, details_by_id = collect(config)
    atomic_write(output_path, render(config, groups_by_state, identities, details_by_id))
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except GrafanaIrmError as error:
        print(f"grayhaven-irm-alert-groups-textfile: {error}", file=sys.stderr)
        raise SystemExit(1) from error
