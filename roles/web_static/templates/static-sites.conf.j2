{% if web_static_tls_mode == "host" %}
# Host TLS catch-all servers reject hostnames that are not explicitly
# configured below. This prevents unknown hostnames from falling through to the
# first configured vhost.
server {
    listen 80 default_server;
    server_name _;

    return 444;
}

server {
    listen 443 ssl default_server;
    server_name _;

    ssl_reject_handshake on;
}
{% endif %}

{% for site in web_static_sites %}
{% if web_static_tls_mode == "host" %}
# Host TLS mode: nginx redirects HTTP to HTTPS and serves local Certbot
# certificates for production and development hostnames.
server {
    listen 80;
    server_name {{ site.domain }};

    return 301 https://{{ site.domain }}$request_uri;
}

server {
    listen 80;
    server_name {{ site.aliases | join(' ') }};

    return 301 https://{{ site.domain }}$request_uri;
}

server {
    listen 80;
    server_name {{ site.dev_domain }};

    return 301 https://{{ site.dev_domain }}$request_uri;
}

server {
    listen 443 ssl;
    server_name {{ site.aliases | join(' ') }};

    ssl_certificate /etc/letsencrypt/live/{{ site.cert_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ site.cert_name }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers PROFILE=SYSTEM;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;

    return 301 https://{{ site.domain }}$request_uri;
}

server {
    listen 443 ssl;
    server_name {{ site.domain }};

    root {{ web_static_root }}/{{ site.root_name }}/prod;
    index index.html;
    autoindex off;

    access_log /var/log/nginx/{{ site.root_name }}.prod.access.log;
    error_log /var/log/nginx/{{ site.root_name }}.prod.error.log;

    ssl_certificate /etc/letsencrypt/live/{{ site.cert_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ site.cert_name }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers PROFILE=SYSTEM;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;

    location /assets/ {
        alias {{ web_static_assets_root }}/;
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}

server {
    listen 443 ssl;
    server_name {{ site.dev_domain }};

    root {{ web_static_root }}/{{ site.root_name }}/dev;
    index index.html;
    autoindex off;

    access_log /var/log/nginx/{{ site.root_name }}.dev.access.log;
    error_log /var/log/nginx/{{ site.root_name }}.dev.error.log;

    ssl_certificate /etc/letsencrypt/live/{{ site.cert_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ site.cert_name }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers PROFILE=SYSTEM;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;

    auth_basic "{{ site.auth_realm }}";
    auth_basic_user_file {{ site.htpasswd_file }};

    location /assets/ {
        alias {{ web_static_assets_root }}/;
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}
{% else %}
# Load balancer TLS mode: DigitalOcean terminates HTTPS and nginx serves HTTP
# backends only. Development hostnames remain protected with basic auth.
server {
    listen 80;
    server_name {{ site.domain }} {{ site.aliases | join(' ') }};

    root {{ web_static_root }}/{{ site.root_name }}/prod;
    index index.html;
    autoindex off;

    access_log /var/log/nginx/{{ site.root_name }}.prod.access.log;
    error_log /var/log/nginx/{{ site.root_name }}.prod.error.log;

    location /assets/ {
        alias {{ web_static_assets_root }}/;
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}

server {
    listen 80;
    server_name {{ site.dev_domain }};

    root {{ web_static_root }}/{{ site.root_name }}/dev;
    index index.html;
    autoindex off;

    access_log /var/log/nginx/{{ site.root_name }}.dev.access.log;
    error_log /var/log/nginx/{{ site.root_name }}.dev.error.log;

    auth_basic "{{ site.auth_realm }}";
    auth_basic_user_file {{ site.htpasswd_file }};

    location /assets/ {
        alias {{ web_static_assets_root }}/;
        try_files $uri =404;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}
{% endif %}

{% endfor %}
