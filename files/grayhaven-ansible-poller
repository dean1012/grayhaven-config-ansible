#!/usr/bin/env bash
set -Eeuo pipefail

RUNNER_ENV="/etc/grayhaven/ansible/runner.env"
STATE_DIR="/var/lib/grayhaven/ansible-poller"
ANSIBLE_HOME="/home/ansible"
ANSIBLE_CONTROL_PRIVATE_KEY="${ANSIBLE_HOME}/.ssh/id_ed25519"
VAULT_DEPLOY_PRIVATE_KEY="${ANSIBLE_HOME}/.ssh/grayhaven_vault_deploy_key"
GITHUB_KNOWN_HOSTS="${ANSIBLE_HOME}/.ssh/github_known_hosts"
GITHUB_META_URL="https://api.github.com/meta"
DEFAULT_REPO_URL="https://github.com/dean1012/grayhaven-config-ansible.git"
DEFAULT_REPO_REF="main"

log() {
  printf '[grayhaven-ansible-poller] %s\n' "$*"
}

require_file() {
  local path="$1"

  if [[ ! -f "$path" ]]; then
    log "Required file is missing: $path"
    exit 1
  fi
}

prepare_github_known_hosts() {
  local github_meta_json
  local github_known_hosts

  install -d -o ansible -g ansible -m 0700 "${ANSIBLE_HOME}/.ssh"

  github_meta_json="$(mktemp)"
  github_known_hosts="$(mktemp)"

  curl -fsSL \
    -H "Accept: application/vnd.github+json" \
    -H "X-GitHub-Api-Version: 2026-03-10" \
    "$GITHUB_META_URL" > "$github_meta_json"

  /usr/bin/python3 - "$github_meta_json" > "$github_known_hosts" <<'PY'
import json
import sys

with open(sys.argv[1], encoding="utf-8") as github_meta_file:
    github_meta = json.load(github_meta_file)

ssh_keys = github_meta.get("ssh_keys") or []
if not ssh_keys:
    raise SystemExit("GitHub meta response did not include ssh_keys.")

for ssh_key in ssh_keys:
    print(f"github.com {ssh_key}")
PY

  install -o ansible -g ansible -m 0644 "$github_known_hosts" "$GITHUB_KNOWN_HOSTS"
  rm -f "$github_meta_json" "$github_known_hosts"
}

remote_ref() {
  local repo_url="$1"
  local repo_ref="$2"
  local private_key="${3:-}"
  local git_ssh_command

  git_ssh_command="ssh -o StrictHostKeyChecking=yes -o UserKnownHostsFile=${GITHUB_KNOWN_HOSTS}"

  if [[ -n "$private_key" ]]; then
    git_ssh_command="ssh -i ${private_key} -o IdentitiesOnly=yes -o StrictHostKeyChecking=yes -o UserKnownHostsFile=${GITHUB_KNOWN_HOSTS}"
  fi

  GIT_SSH_COMMAND="$git_ssh_command" \
    git ls-remote "$repo_url" "refs/heads/${repo_ref}" "refs/tags/${repo_ref}" | awk 'NR == 1 { print $1 }'
}

persist_ref() {
  local path="$1"
  local value="$2"
  local temp_path

  temp_path="$(mktemp "${STATE_DIR}/.ref.XXXXXX")"
  printf '%s\n' "$value" > "$temp_path"
  mv "$temp_path" "$path"
}

main() {
  require_file "$RUNNER_ENV"
  require_file "$ANSIBLE_CONTROL_PRIVATE_KEY"
  require_file "$VAULT_DEPLOY_PRIVATE_KEY"

  # shellcheck disable=SC1090
  source "$RUNNER_ENV"

  REPO_URL="${REPO_URL:-$DEFAULT_REPO_URL}"
  REPO_REF="${REPO_REF:-$DEFAULT_REPO_REF}"

  prepare_github_known_hosts

  install -d -o root -g root -m 0755 "$STATE_DIR"

  local config_ref
  local vault_ref
  local previous_config_ref
  local previous_vault_ref

  config_ref="$(remote_ref "$REPO_URL" "$REPO_REF")"
  vault_ref="$(remote_ref "$VAULT_REPO_URL" "$VAULT_REPO_REF" "$VAULT_DEPLOY_PRIVATE_KEY")"
  if [[ -z "$config_ref" || -z "$vault_ref" ]]; then
    log "Unable to resolve one or more tracked repository refs."
    exit 1
  fi

  previous_config_ref="$(cat "${STATE_DIR}/config.ref" 2>/dev/null || true)"
  previous_vault_ref="$(cat "${STATE_DIR}/vault.ref" 2>/dev/null || true)"

  if [[ "$config_ref" == "$previous_config_ref" && "$vault_ref" == "$previous_vault_ref" ]]; then
    log "No repository changes detected."
    exit 0
  fi

  log "Repository change detected; triggering Ansible runner."
  systemctl start --no-block grayhaven-ansible-runner.service

  # Record the observed refs only after systemd accepts the runner request. If
  # the trigger fails, the next poll should retry the same repository change.
  persist_ref "${STATE_DIR}/config.ref" "$config_ref"
  persist_ref "${STATE_DIR}/vault.ref" "$vault_ref"
}

main "$@"
