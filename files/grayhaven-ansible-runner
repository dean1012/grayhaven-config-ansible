#!/usr/bin/env bash
set -Eeuo pipefail

LOCK_FILE="/run/grayhaven-ansible-runner.lock"
RUNNER_ENV="/etc/grayhaven/ansible/runner.env"
DO_TOKEN_ENV="/etc/grayhaven/ansible/secrets/do-api-token.env"
DISCORD_WEBHOOK_ENV="/etc/grayhaven/ansible/secrets/discord-webhook.env"
ADMIN_ACCESS_VARS="/etc/grayhaven/ansible/secrets/admin-access.yml"
MANAGED_BASELINE_VARS="/etc/grayhaven/ansible/secrets/managed-baseline.yml"
RUNNER_VARS="/run/grayhaven-ansible-runner-vars.yml"
RUNNER_PLAYBOOK_LOG="/run/grayhaven-ansible-runner-playbook.log"
ANSIBLE_HOME="/home/ansible"
ANSIBLE_CONTROL_PRIVATE_KEY="${ANSIBLE_HOME}/.ssh/id_ed25519"
CHECKOUT_PARENT="${ANSIBLE_HOME}"
DEFAULT_CHECKOUT_DIR="${ANSIBLE_HOME}/grayhaven-config-ansible"
DEFAULT_REPO_URL="https://github.com/dean1012/grayhaven-config-ansible.git"
DEFAULT_REPO_REF="main"

log() {
  printf '[grayhaven-ansible-runner] %s\n' "$*"
}

send_failure_notification() {
  local status="$1"
  local failed_targets

  if [[ -z "${DISCORD_WEBHOOK_URL:-}" ]]; then
    log "Discord webhook URL is unavailable; skipping failure notification."
    return 0
  fi

  log "Sending Discord failure notification."
  failed_targets="$(failed_playbook_targets)"
  if [[ -z "$failed_targets" ]]; then
    failed_targets="Ansible playbook run"
  fi

  DISCORD_TARGET="$failed_targets"
  DISCORD_TIMESTAMP="$(TZ="${MANAGED_BASELINE_TIMEZONE:-America/Chicago}" date '+%Y-%m-%d %I:%M %p')"
  export DISCORD_TARGET DISCORD_TIMESTAMP

  /usr/bin/python3 - <<'PY' | curl --fail --silent --show-error \
    --header "Content-Type: application/json" \
    --request POST \
    --data @- \
    "$DISCORD_WEBHOOK_URL" >/dev/null || log "Discord failure notification could not be delivered."
import json
import os

description = (
    f"{os.environ['DISCORD_TARGET']}\n\n"
    f"Environment: {os.environ.get('GRAYHAVEN_ENVIRONMENT', 'prod')}\n"
    f"{os.environ['DISCORD_TIMESTAMP']}"
)

print(
    json.dumps(
        {
            "embeds": [
                {
                    "title": "Ansible Configuration Failed - Please Investigate",
                    "description": description,
                    "color": 14042437,
                }
            ]
        }
    )
)
PY

  return "$status"
}

failed_playbook_targets() {
  if [[ ! -f "$RUNNER_PLAYBOOK_LOG" ]]; then
    return 0
  fi

  /usr/bin/python3 - "$RUNNER_PLAYBOOK_LOG" <<'PY'
import re
import sys

failed_hosts = []
recap_re = re.compile(r"^(?P<host>\S+)\s+:.*\bunreachable=(?P<unreachable>\d+).*failed=(?P<failed>\d+)")

with open(sys.argv[1], encoding="utf-8", errors="replace") as log_file:
    for line in log_file:
        match = recap_re.search(line)
        if not match:
            continue

        if int(match.group("unreachable")) > 0 or int(match.group("failed")) > 0:
            failed_hosts.append(match.group("host"))

failed_hosts = list(dict.fromkeys(failed_hosts))


def host_order(host):
    if "bastion" in host:
        return (0, host)

    if "web" in host:
        return (1, host)

    return (2, host)


print("\n".join(sorted(failed_hosts, key=host_order)))
PY
}

on_error() {
  local status="$?"

  set +e
  send_failure_notification "$status"
  exit "$status"
}

run_as_ansible() {
  runuser -u ansible -- "$@"
}

require_file() {
  local path="$1"

  if [[ ! -f "$path" ]]; then
    log "Required file is missing: $path"
    exit 1
  fi
}

prepare_inventory_known_hosts() {
  local inventory_json
  local scan_targets

  inventory_json="$(mktemp)"
  /usr/local/bin/ansible-inventory \
    --inventory "${CHECKOUT_DIR}/inventory" \
    --list > "$inventory_json"

  scan_targets="$(
    /usr/bin/python3 - "$inventory_json" <<'PY'
import json
import sys

with open(sys.argv[1], encoding="utf-8") as inventory_file:
    inventory = json.load(inventory_file)

hostvars = inventory.get("_meta", {}).get("hostvars", {})
targets = []

def unwrap_ansible_value(value):
    if isinstance(value, dict) and "__ansible_unsafe" in value:
        return value["__ansible_unsafe"]

    return value

for variables in hostvars.values():
    if unwrap_ansible_value(variables.get("ansible_connection")) == "local":
        continue

    ansible_host = unwrap_ansible_value(variables.get("ansible_host"))
    if ansible_host:
        targets.append(str(ansible_host))

print("\n".join(dict.fromkeys(targets)))
PY
  )"

  rm -f "$inventory_json"

  if [[ -z "$scan_targets" ]]; then
    log "No remote inventory targets require SSH known-host preparation."
    return 0
  fi

  log "Preparing SSH known hosts for remote inventory targets."
  install -d -o root -g root -m 0755 /etc/ssh
  # shellcheck disable=SC2086
  ssh-keyscan -T 5 -t ed25519 $scan_targets > /etc/ssh/ssh_known_hosts
  chmod 0644 /etc/ssh/ssh_known_hosts
}

checkout_ref() {
  local repo_ref="$1"

  run_as_ansible git -C "$CHECKOUT_DIR" fetch --prune origin \
    '+refs/heads/*:refs/remotes/origin/*' \
    '+refs/tags/*:refs/tags/*'

  if run_as_ansible git -C "$CHECKOUT_DIR" rev-parse --verify --quiet "origin/${repo_ref}" >/dev/null; then
    run_as_ansible git -C "$CHECKOUT_DIR" checkout -B "$repo_ref" "origin/${repo_ref}"
  else
    run_as_ansible git -C "$CHECKOUT_DIR" checkout --detach "$repo_ref"
  fi

  run_as_ansible git -C "$CHECKOUT_DIR" reset --hard HEAD
}

main() {
  exec 9>"$LOCK_FILE"
  if ! flock -n 9; then
    log "Another runner invocation is already active."
    exit 1
  fi

  require_file "$RUNNER_ENV"
  require_file "$DO_TOKEN_ENV"
  require_file "$DISCORD_WEBHOOK_ENV"
  require_file "$ADMIN_ACCESS_VARS"
  require_file "$MANAGED_BASELINE_VARS"
  require_file "$ANSIBLE_CONTROL_PRIVATE_KEY"

  # shellcheck disable=SC1090
  source "$RUNNER_ENV"
  # shellcheck disable=SC1090
  source "$DO_TOKEN_ENV"
  # shellcheck disable=SC1090
  source "$DISCORD_WEBHOOK_ENV"

  export DO_API_TOKEN
  export HOME="/root"
  trap on_error ERR

  REPO_URL="${REPO_URL:-$DEFAULT_REPO_URL}"
  REPO_REF="${REPO_REF:-$DEFAULT_REPO_REF}"
  CHECKOUT_DIR="${CHECKOUT_DIR:-$DEFAULT_CHECKOUT_DIR}"
  export ANSIBLE_CONFIG="${CHECKOUT_DIR}/ansible.cfg"

  if [[ ! "${DISCORD_WEBHOOK_URL:-}" =~ ^https://discord.com/api/webhooks/([^/]+)/([^/]+)$ ]]; then
    log "Discord webhook URL has an unexpected format."
    exit 1
  fi

  DISCORD_WEBHOOK_ID="${BASH_REMATCH[1]}"
  DISCORD_WEBHOOK_TOKEN="${BASH_REMATCH[2]}"
  GRAYHAVEN_ENVIRONMENT="${GRAYHAVEN_ENVIRONMENT:-prod}"
  export DISCORD_WEBHOOK_ID DISCORD_WEBHOOK_TOKEN GRAYHAVEN_ENVIRONMENT

  log "Preparing checkout ${CHECKOUT_DIR} at ref ${REPO_REF}."
  install -d -o ansible -g ansible -m 0755 "$CHECKOUT_PARENT"

  if [[ ! -d "${CHECKOUT_DIR}/.git" ]]; then
    run_as_ansible git clone "$REPO_URL" "$CHECKOUT_DIR"
  fi

  chown -R ansible:ansible "$CHECKOUT_DIR"
  checkout_ref "$REPO_REF"

  log "Preparing runtime variables derived from local control state."
  ANSIBLE_CONTROL_PUBLIC_KEY="$(ssh-keygen -y -f "$ANSIBLE_CONTROL_PRIVATE_KEY")"
  export ANSIBLE_CONTROL_PUBLIC_KEY
  /usr/bin/python3 - <<'PY' > "$RUNNER_VARS"
import json
import os

print(
    "managed_baseline_ansible_control_public_key: "
    + json.dumps(os.environ["ANSIBLE_CONTROL_PUBLIC_KEY"])
)
print(
    "automation_notifications_discord_webhook_id: "
    + json.dumps(os.environ["DISCORD_WEBHOOK_ID"])
)
print(
    "automation_notifications_discord_webhook_token: "
    + json.dumps(os.environ["DISCORD_WEBHOOK_TOKEN"])
)
print(
    "automation_notifications_environment: "
    + json.dumps(os.environ["GRAYHAVEN_ENVIRONMENT"])
)
PY

  log "Ensuring pip-managed Ansible runtime is available."
  /usr/bin/python3 -m pip install --upgrade --root-user-action=ignore pip
  if ! /usr/local/bin/ansible --version 2>/dev/null | head -n 1 | grep -q "core 2.21.0"; then
    /usr/bin/python3 -m pip install \
      --upgrade \
      --ignore-installed \
      --root-user-action=ignore \
      ansible-core==2.21.0
  fi
  /usr/local/bin/ansible --version

  log "Installing pinned Python dependencies."
  /usr/bin/python3 -m pip install \
    --root-user-action=ignore \
    --requirement "${CHECKOUT_DIR}/pip3_requirements.txt"

  log "Installing pinned Ansible Galaxy collections."
  /usr/local/bin/ansible-galaxy collection install \
    --requirements-file "${CHECKOUT_DIR}/galaxy_requirements.yml" \
    --force

  prepare_inventory_known_hosts

  log "Running full site playbook."
  rm -f "$RUNNER_PLAYBOOK_LOG"
  /usr/local/bin/ansible-playbook \
    --inventory "${CHECKOUT_DIR}/inventory" \
    "${CHECKOUT_DIR}/playbooks/site.yml" \
    --extra-vars "@${MANAGED_BASELINE_VARS}" \
    --extra-vars "@${RUNNER_VARS}" \
    --extra-vars "@${ADMIN_ACCESS_VARS}" 2>&1 | tee "$RUNNER_PLAYBOOK_LOG"
}

main "$@"
