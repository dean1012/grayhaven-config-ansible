#!/usr/bin/env bash
set -Eeuo pipefail

RUNNER_RUNTIME_DIR="/run/grayhaven-ansible-runner"
LOCK_FILE="${RUNNER_RUNTIME_DIR}/runner.lock"
PENDING_FILE="${RUNNER_RUNTIME_DIR}/runner.pending"
RUNNER_ENV="/etc/grayhaven/ansible/runner.env"
VAULT_PASSWORD_FILE="/etc/grayhaven/ansible/secrets/vault-password"
RUNNER_VARS="${RUNNER_RUNTIME_DIR}/vars.yml"
RUNNER_SECRET_ENV="${RUNNER_RUNTIME_DIR}/secrets.env"
RUNNER_PLAYBOOK_LOG="${RUNNER_RUNTIME_DIR}/playbook.log"
ROTATE_VAULT_PASSWORD_FILE=""
OBSERVABILITY_TEXTFILE_DIR="/var/lib/grayhaven/observability/textfile"
ANSIBLE_HOME="/home/ansible"
RUNNER_WORK_DIR="${ANSIBLE_HOME}/ansible-runner"
ANSIBLE_CONTROL_PRIVATE_KEY="${ANSIBLE_HOME}/.ssh/id_ed25519"
VAULT_DEPLOY_PRIVATE_KEY="${ANSIBLE_HOME}/.ssh/grayhaven_vault_deploy_key"
GITHUB_KNOWN_HOSTS="${ANSIBLE_HOME}/.ssh/github_known_hosts"
INVENTORY_KNOWN_HOSTS="${ANSIBLE_HOME}/.ssh/known_hosts"
GITHUB_META_URL="https://api.github.com/meta"
ANSIBLE_RUNTIME_VENV="${ANSIBLE_HOME}/ansible-runner/ansible-runtime"
ANSIBLE_COLLECTIONS_PATH="${ANSIBLE_HOME}/.ansible/collections"
CHECKOUT_PARENT="${ANSIBLE_HOME}"
DEFAULT_CHECKOUT_DIR="${ANSIBLE_HOME}/grayhaven-config-ansible"
DEFAULT_VAULT_CHECKOUT_DIR="${ANSIBLE_HOME}/grayhaven-vault"
DEFAULT_REPO_URL="https://github.com/dean1012/grayhaven-config-ansible.git"
DEFAULT_REPO_REF="main"
ANSIBLE_BIN="${ANSIBLE_RUNTIME_VENV}/bin/ansible"
ANSIBLE_GALAXY_BIN="${ANSIBLE_RUNTIME_VENV}/bin/ansible-galaxy"
ANSIBLE_INVENTORY_BIN="${ANSIBLE_RUNTIME_VENV}/bin/ansible-inventory"
ANSIBLE_PLAYBOOK_BIN="${ANSIBLE_RUNTIME_VENV}/bin/ansible-playbook"
ANSIBLE_VAULT_BIN="${ANSIBLE_RUNTIME_VENV}/bin/ansible-vault"
RUNNER_COMMAND="converge"
GCS_CLEANUP_EXECUTE="false"
RUNNER_EXTRA_VARS_FILES=()

###############################################################################
# Logging, guards, and cleanup
###############################################################################

log() {
  printf '[grayhaven-ansible-runner] %s\n' "$*"
}

drop_to_ansible() {
  if running_as_ansible; then
    export HOME="$ANSIBLE_HOME"
    export USER="ansible"
    export LOGNAME="ansible"
    return
  fi

  if [[ "$(id -u)" -ne 0 ]]; then
    log "Runner must be invoked as root or ansible."
    exit 1
  fi

  exec runuser -u ansible -- env \
    HOME="$ANSIBLE_HOME" \
    USER="ansible" \
    LOGNAME="ansible" \
    "$0" "$@"
}

usage() {
  cat <<'EOF'
Usage:
  grayhaven-ansible-runner
  grayhaven-ansible-runner --converge
  grayhaven-ansible-runner --cleanup-gcs-restic-buckets [--execute]
  grayhaven-ansible-runner --rotate-vault-password --extra-vars-file <path>
  grayhaven-ansible-runner --rotate-vault-deploy-key
  grayhaven-ansible-runner --rotate-ansible-control-key

Commands:
  --converge
      Run the normal full Ansible convergence. This is the default.

  --cleanup-gcs-restic-buckets
      Run the GCS restic bucket cleanup maintenance playbook in dry-run mode.

  --execute
      Delete stale GCS restic buckets. Only valid with
      --cleanup-gcs-restic-buckets.

  --extra-vars-file <path>
      Pass an extra-vars file to the selected maintenance playbook. Required
      for --rotate-vault-password.
EOF
}

parse_args() {
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --converge|converge)
        RUNNER_COMMAND="converge"
        ;;
      --cleanup-gcs-restic-buckets|cleanup-gcs-restic-buckets)
        RUNNER_COMMAND="cleanup-gcs-restic-buckets"
        ;;
      --rotate-vault-password|rotate-vault-password)
        RUNNER_COMMAND="rotate-vault-password"
        ;;
      --rotate-vault-deploy-key|rotate-vault-deploy-key)
        RUNNER_COMMAND="rotate-vault-deploy-key"
        ;;
      --rotate-ansible-control-key|rotate-ansible-control-key)
        RUNNER_COMMAND="rotate-ansible-control-key"
        ;;
      --execute)
        GCS_CLEANUP_EXECUTE="true"
        ;;
      --extra-vars-file)
        shift
        if [[ "$#" -eq 0 || -z "$1" ]]; then
          log "--extra-vars-file requires a path."
          usage
          exit 1
        fi
        RUNNER_EXTRA_VARS_FILES+=("$1")
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      *)
        log "Unknown runner argument: $1"
        usage
        exit 1
        ;;
    esac
    shift
  done

  if [[ "$GCS_CLEANUP_EXECUTE" == "true" && "$RUNNER_COMMAND" != "cleanup-gcs-restic-buckets" ]]; then
    log "--execute is only valid with --cleanup-gcs-restic-buckets."
    usage
    exit 1
  fi

  if [[ "$RUNNER_COMMAND" == "rotate-vault-password" && "${#RUNNER_EXTRA_VARS_FILES[@]}" -eq 0 ]]; then
    log "--rotate-vault-password requires --extra-vars-file."
    usage
    exit 1
  fi
}

running_as_ansible() {
  [[ "$(id -un)" == "ansible" ]]
}

run_as_ansible() {
  if running_as_ansible; then
    env HOME="$ANSIBLE_HOME" USER="ansible" LOGNAME="ansible" "$@"
    return
  fi

  runuser -u ansible -- env \
    HOME="$ANSIBLE_HOME" \
    USER="ansible" \
    LOGNAME="ansible" \
    "$@"
}

run_git_as_ansible() {
  local private_key="$1"
  local git_ssh_command
  shift

  git_ssh_command="ssh -o StrictHostKeyChecking=yes -o UserKnownHostsFile=${GITHUB_KNOWN_HOSTS}"

  if [[ -n "$private_key" ]]; then
    git_ssh_command="ssh -i ${private_key} -o IdentitiesOnly=yes -o StrictHostKeyChecking=yes -o UserKnownHostsFile=${GITHUB_KNOWN_HOSTS}"
  fi

  run_as_ansible env \
    GIT_SSH_COMMAND="$git_ssh_command" \
    git "$@"
}

require_file() {
  local path="$1"

  if [[ ! -f "$path" ]]; then
    log "Required file is missing: $path"
    exit 1
  fi
}

require_env() {
  local name="$1"

  if [[ -z "${!name:-}" ]]; then
    log "Required environment variable is unset: $name"
    exit 1
  fi
}

cleanup_runtime_files() {
  rm -f "$RUNNER_SECRET_ENV" "$RUNNER_VARS"
  if [[ -n "${ROTATE_VAULT_PASSWORD_FILE:-}" ]]; then
    rm -f "$ROTATE_VAULT_PASSWORD_FILE"
  fi
}

grafana_cloud_enabled() {
  local config_file="${VAULT_CHECKOUT_DIR:-}/config.yml"

  [[ -f "$config_file" ]] || return 1

  /usr/bin/python3 - "$config_file" <<'PY'
import sys

import yaml

with open(sys.argv[1], encoding="utf-8") as config_file:
    config = yaml.safe_load(config_file) or {}

grafana_cloud = (config.get("observability") or {}).get("grafana_cloud") or {}
raise SystemExit(0 if grafana_cloud.get("enabled") is True else 1)
PY
}

write_convergence_metric() {
  local success_value="$1"
  local host="${GRAYHAVEN_HOSTNAME:-$(hostname -f)}"
  local environment="${GRAYHAVEN_ENVIRONMENT:-unknown}"
  local tmp_file

  if ! grafana_cloud_enabled; then
    return 0
  fi

  install -d -m 0755 "$OBSERVABILITY_TEXTFILE_DIR"
  tmp_file="$(mktemp "${OBSERVABILITY_TEXTFILE_DIR}/ansible-convergence.XXXXXX")"
  {
    printf '# HELP grayhaven_ansible_convergence_last_success Last Grayhaven Ansible convergence success status.\n'
    printf '# TYPE grayhaven_ansible_convergence_last_success gauge\n'
    printf 'grayhaven_ansible_convergence_last_success{host="%s",environment="%s"} %s\n' \
      "$host" \
      "$environment" \
      "$success_value"
    printf '# HELP grayhaven_ansible_convergence_last_timestamp_seconds Last Grayhaven Ansible convergence completion timestamp.\n'
    printf '# TYPE grayhaven_ansible_convergence_last_timestamp_seconds gauge\n'
    printf 'grayhaven_ansible_convergence_last_timestamp_seconds{host="%s",environment="%s"} %s\n' \
      "$host" \
      "$environment" \
      "$(date +%s)"
  } > "$tmp_file"
  chmod 0644 "$tmp_file"
  mv "$tmp_file" "${OBSERVABILITY_TEXTFILE_DIR}/ansible-convergence.prom"
}

###############################################################################
# Failure notification
###############################################################################

failed_playbook_targets() {
  if [[ ! -f "$RUNNER_PLAYBOOK_LOG" ]]; then
    return 0
  fi

  /usr/bin/python3 - "$RUNNER_PLAYBOOK_LOG" <<'PY'
import re
import sys

failed_hosts = []
recap_re = re.compile(r"^(?P<host>\S+)\s+:.*\bunreachable=(?P<unreachable>\d+).*failed=(?P<failed>\d+)")

with open(sys.argv[1], encoding="utf-8", errors="replace") as log_file:
    for line in log_file:
        match = recap_re.search(line)
        if not match:
            continue

        if int(match.group("unreachable")) > 0 or int(match.group("failed")) > 0:
            failed_hosts.append(match.group("host"))

failed_hosts = list(dict.fromkeys(failed_hosts))


def host_order(host):
    if "bastion" in host:
        return (0, host)

    if "web" in host:
        return (1, host)

    return (2, host)


print("\n".join(sorted(failed_hosts, key=host_order)))
PY
}

send_failure_notification() {
  local status="$1"
  local failed_targets

  if [[ -z "${DISCORD_WEBHOOK_URL:-}" ]]; then
    log "Discord webhook URL is unavailable; skipping failure notification."
    return 0
  fi

  log "Sending Discord failure notification."
  failed_targets="$(failed_playbook_targets)"
  if [[ -z "$failed_targets" ]]; then
    failed_targets="Ansible runner command"
  fi

  DISCORD_TARGET="$failed_targets"
  DISCORD_TIMESTAMP="$(TZ="${MANAGED_BASELINE_TIMEZONE:-America/Chicago}" date '+%Y-%m-%d %I:%M %p %Z')"
  export DISCORD_TARGET DISCORD_TIMESTAMP

  /usr/bin/python3 - <<'PY' | curl --fail --silent --show-error \
    --header "Content-Type: application/json" \
    --request POST \
    --data @- \
    "$DISCORD_WEBHOOK_URL" >/dev/null || log "Discord failure notification could not be delivered."
import json
import os

description = (
    f"{os.environ['DISCORD_TARGET']}\n\n"
    f"Environment: {os.environ.get('GRAYHAVEN_ENVIRONMENT', 'unknown')}\n"
    f"{os.environ['DISCORD_TIMESTAMP']}"
)

print(
    json.dumps(
        {
            "embeds": [
                {
                    "title": "Ansible Configuration Failed - Please Investigate",
                    "description": description,
                    "color": 14042437,
                }
            ]
        }
    )
)
PY

  return "$status"
}

on_error() {
  local status="$?"

  set +e
  if [[ "$RUNNER_COMMAND" == "converge" ]]; then
    write_convergence_metric 0 || log "Convergence failure metric could not be written."
    send_failure_notification "$status"
  else
    log "Runner command failed: $RUNNER_COMMAND"
  fi
  exit "$status"
}

###############################################################################
# Git and SSH preparation
###############################################################################

checkout_ref() {
  local checkout_dir="$1"
  local repo_url="$2"
  local repo_ref="$3"
  local private_key="${4:-}"

  if [[ ! -d "${checkout_dir}/.git" ]]; then
    run_git_as_ansible "$private_key" clone "$repo_url" "$checkout_dir"
  fi

  run_git_as_ansible "$private_key" -C "$checkout_dir" fetch --prune origin \
    '+refs/heads/*:refs/remotes/origin/*' \
    '+refs/tags/*:refs/tags/*'

  if run_git_as_ansible "$private_key" -C "$checkout_dir" rev-parse --verify --quiet "origin/${repo_ref}" >/dev/null; then
    run_git_as_ansible "$private_key" -C "$checkout_dir" checkout -B "$repo_ref" "origin/${repo_ref}"
  else
    run_git_as_ansible "$private_key" -C "$checkout_dir" checkout --detach "$repo_ref"
  fi

  run_git_as_ansible "$private_key" -C "$checkout_dir" reset --hard HEAD
  # These checkouts are owned by the runner. Cleaning them prevents deleted
  # repository files from lingering across convergence runs.
  run_git_as_ansible "$private_key" -C "$checkout_dir" clean -ffd
}

prepare_github_known_hosts() {
  local github_meta_json
  local github_known_hosts

  if running_as_ansible; then
    install -d -m 0700 "${ANSIBLE_HOME}/.ssh"
  else
    install -d -o ansible -g ansible -m 0700 "${ANSIBLE_HOME}/.ssh"
  fi

  github_meta_json="$(mktemp)"
  github_known_hosts="$(mktemp)"

  curl -fsSL \
    -H "Accept: application/vnd.github+json" \
    -H "X-GitHub-Api-Version: 2026-03-10" \
    "$GITHUB_META_URL" > "$github_meta_json"

  /usr/bin/python3 - "$github_meta_json" > "$github_known_hosts" <<'PY'
import json
import sys

with open(sys.argv[1], encoding="utf-8") as github_meta_file:
    github_meta = json.load(github_meta_file)

ssh_keys = github_meta.get("ssh_keys") or []
if not ssh_keys:
    raise SystemExit("GitHub meta response did not include ssh_keys.")

for ssh_key in ssh_keys:
    print(f"github.com {ssh_key}")
PY

  if running_as_ansible; then
    install -m 0644 "$github_known_hosts" "$GITHUB_KNOWN_HOSTS"
  else
    install -o ansible -g ansible -m 0644 "$github_known_hosts" "$GITHUB_KNOWN_HOSTS"
  fi

  rm -f "$github_meta_json" "$github_known_hosts"
}

prepare_inventory_known_hosts() {
  local inventory_json
  local target_rows
  local inventory_known_hosts
  local host_alias
  local ssh_target
  local scan_output
  local scanned_host
  local key_type
  local key_body

  if [[ ! -f "$INVENTORY_KNOWN_HOSTS" ]]; then
    log "Temporary inventory known-hosts bridge is absent; using managed global SSH known hosts."
    return 0
  fi

  inventory_json="$(mktemp)"
  run_as_ansible "$ANSIBLE_INVENTORY_BIN" \
    --inventory "${CHECKOUT_DIR}/inventory" \
    --list > "$inventory_json"

  target_rows="$(
    /usr/bin/python3 - "$inventory_json" <<'PY'
import json
import sys

with open(sys.argv[1], encoding="utf-8") as inventory_file:
    inventory = json.load(inventory_file)

hostvars = inventory.get("_meta", {}).get("hostvars", {})
targets = []


def unwrap_ansible_value(value):
    if isinstance(value, dict) and "__ansible_unsafe" in value:
        return value["__ansible_unsafe"]

    return value


for inventory_hostname, variables in hostvars.items():
    if unwrap_ansible_value(variables.get("ansible_connection")) == "local":
        continue

    ansible_host = unwrap_ansible_value(variables.get("ansible_host"))
    if ansible_host:
        targets.append((str(inventory_hostname), str(ansible_host)))

for host_alias, ssh_target in dict.fromkeys(targets):
    print(f"{host_alias}\t{ssh_target}")
PY
  )"

  rm -f "$inventory_json"

  if [[ -z "$target_rows" ]]; then
    log "No remote inventory targets require SSH known-host preparation."
    return 0
  fi

  log "Preparing temporary SSH known hosts for first convergence."
  inventory_known_hosts="$(mktemp)"

  while IFS=$'\t' read -r host_alias ssh_target; do
    [[ -n "$host_alias" && -n "$ssh_target" ]] || continue

    scan_output="$(ssh-keyscan -T 5 -t ed25519 "$ssh_target" 2>/dev/null)"
    if [[ -z "$scan_output" ]]; then
      log "Unable to scan SSH host key for ${host_alias} via ${ssh_target}."
      exit 1
    fi

    while read -r scanned_host key_type key_body _; do
      [[ -n "$scanned_host" && -n "$key_type" && -n "$key_body" ]] || continue
      printf '%s %s %s\n' "$ssh_target" "$key_type" "$key_body" >> "$inventory_known_hosts"
      if [[ "$host_alias" != "$ssh_target" ]]; then
        printf '%s %s %s\n' "$host_alias" "$key_type" "$key_body" >> "$inventory_known_hosts"
      fi
    done <<< "$scan_output"
  done <<< "$target_rows"

  if running_as_ansible; then
    install -m 0644 "$inventory_known_hosts" "$INVENTORY_KNOWN_HOSTS"
  else
    install -o ansible -g ansible -m 0644 "$inventory_known_hosts" "$INVENTORY_KNOWN_HOSTS"
  fi

  rm -f "$inventory_known_hosts"
}

###############################################################################
# Runtime dependency installation
###############################################################################

install_ansible_runtime() {
  log "Ensuring pip-managed Ansible runtime is available."
  run_as_ansible install -d -m 0750 "$(dirname "$ANSIBLE_RUNTIME_VENV")"
  run_as_ansible install -d -m 0755 "$ANSIBLE_COLLECTIONS_PATH"
  run_as_ansible /usr/bin/python3 -m venv "$ANSIBLE_RUNTIME_VENV"
  run_as_ansible "${ANSIBLE_RUNTIME_VENV}/bin/python" -m pip install --upgrade pip

  log "Installing hash-pinned Python and Ansible runtime dependencies."
  run_as_ansible "${ANSIBLE_RUNTIME_VENV}/bin/python" -m pip install \
    --upgrade \
    --require-hashes \
    --requirement "${CHECKOUT_DIR}/pip3_requirements.txt"
  export PATH="${ANSIBLE_RUNTIME_VENV}/bin:${PATH}"
  run_as_ansible "$ANSIBLE_BIN" --version

  log "Installing pinned Ansible Galaxy collections."
  run_as_ansible env \
    HOME="$ANSIBLE_HOME" \
    ANSIBLE_COLLECTIONS_PATH="$ANSIBLE_COLLECTIONS_PATH" \
    ANSIBLE_COLLECTIONS_PATHS="$ANSIBLE_COLLECTIONS_PATH" \
    ANSIBLE_GALAXY_BIN="$ANSIBLE_GALAXY_BIN" \
    "${CHECKOUT_DIR}/scripts/install-galaxy-collections"
}

###############################################################################
# Secret and inventory-derived runtime state
###############################################################################

render_secret_environment() {
  install -m 0600 /dev/null "$RUNNER_SECRET_ENV"
  /usr/bin/python3 - "$VAULT_CHECKOUT_DIR" "$VAULT_PASSWORD_FILE" <<'PY' > "$RUNNER_SECRET_ENV"
import io
import os
import shlex
import subprocess
import sys

import yaml

vault_checkout_dir = sys.argv[1]
vault_password_file = sys.argv[2]

with open(os.path.join(vault_checkout_dir, "config.yml"), encoding="utf-8") as config_file:
    config = yaml.safe_load(config_file) or {}

result = subprocess.run(
    [
        os.environ["ANSIBLE_VAULT_BIN"],
        "view",
        "--vault-password-file",
        vault_password_file,
        os.path.join(vault_checkout_dir, "vault", "bastion.yml"),
    ],
    check=True,
    capture_output=True,
    text=True,
)
bastion = yaml.safe_load(io.StringIO(result.stdout)) or {}

selector = config.get("discord_webhook")
webhooks = bastion.get("discord_webhooks", {})
webhook_url = webhooks.get(selector)

if not webhook_url:
    raise SystemExit(f"discord_webhook selector {selector!r} does not match a configured webhook")

certificate_environment = config.get("certificate_environment")
if certificate_environment not in ["staging", "production"]:
    raise SystemExit("certificate_environment must be staging or production")

inventory_token = bastion.get("digitalocean_inventory_api_token")
if not inventory_token:
    raise SystemExit("digitalocean_inventory_api_token is missing from bastion vault data")

print(f"DO_API_TOKEN={shlex.quote(str(inventory_token))}")
print(f"DISCORD_WEBHOOK_URL={shlex.quote(str(webhook_url))}")
print(f"GRAYHAVEN_CERTIFICATE_ENVIRONMENT={shlex.quote(str(certificate_environment))}")
PY
  # shellcheck disable=SC1090
  source "$RUNNER_SECRET_ENV"
  export DO_API_TOKEN DISCORD_WEBHOOK_URL GRAYHAVEN_CERTIFICATE_ENVIRONMENT
}

refresh_runtime_state_from_inventory() {
  local inventory_json
  local runtime_env

  log "Refreshing runtime state from DigitalOcean inventory."
  inventory_json="$(mktemp)"
  runtime_env="$(mktemp)"

  run_as_ansible "$ANSIBLE_INVENTORY_BIN" \
    --inventory "${CHECKOUT_DIR}/inventory" \
    --list > "$inventory_json"

  /usr/bin/python3 - "$inventory_json" > "$runtime_env" <<'PY'
import json
import os
import shlex
import sys

with open(sys.argv[1], encoding="utf-8") as inventory_file:
    inventory = json.load(inventory_file)

hostname = os.environ.get("GRAYHAVEN_HOSTNAME", "")
hostvars = inventory.get("_meta", {}).get("hostvars", {})
variables = hostvars.get(hostname)

if variables is None:
    raise SystemExit(f"Current host {hostname!r} was not found in DigitalOcean inventory")

def unwrap_ansible_value(value):
    if isinstance(value, dict) and "__ansible_unsafe" in value:
        return value["__ansible_unsafe"]

    if isinstance(value, list):
        return [unwrap_ansible_value(item) for item in value]

    return value


tags = unwrap_ansible_value(variables.get("do_tags", []))
environment_tags = [
    tag
    for host_variables in hostvars.values()
    for tag in unwrap_ansible_value(host_variables.get("do_tags", []))
]

if "tls-mode-load-balancer" in environment_tags or "tls-mode-load_balancer" in environment_tags:
    tls_mode = "load_balancer"
elif "tls-mode-host" in environment_tags:
    tls_mode = "host"
else:
    raise SystemExit("DigitalOcean inventory does not include a tls-mode tag")

is_control_node = "true" if "control-node" in tags else "false"

print(f"GRAYHAVEN_TLS_MODE={shlex.quote(tls_mode)}")
print(f"GRAYHAVEN_IS_CONTROL_NODE={shlex.quote(is_control_node)}")
PY

  # shellcheck disable=SC1090
  source "$runtime_env"
  export GRAYHAVEN_TLS_MODE GRAYHAVEN_IS_CONTROL_NODE

  rm -f "$inventory_json" "$runtime_env"
}

