###############################################################################
# Runner orchestration
###############################################################################

prepare_runner_runtime() {
  require_file "$RUNNER_ENV"
  require_file "$VAULT_PASSWORD_FILE"
  require_file "$ANSIBLE_CONTROL_PRIVATE_KEY"
  require_file "$VAULT_DEPLOY_PRIVATE_KEY"

  # shellcheck disable=SC1090
  source "$RUNNER_ENV"

  REPO_URL="${REPO_URL:-$DEFAULT_REPO_URL}"
  REPO_REF="${REPO_REF:-$DEFAULT_REPO_REF}"
  CHECKOUT_DIR="${CHECKOUT_DIR:-$DEFAULT_CHECKOUT_DIR}"
  VAULT_CHECKOUT_DIR="${VAULT_CHECKOUT_DIR:-$DEFAULT_VAULT_CHECKOUT_DIR}"
  require_env VAULT_REPO_URL
  require_env VAULT_REPO_REF
  require_env GRAYHAVEN_ENVIRONMENT
  require_env GRAYHAVEN_HOSTNAME
  export REPO_REF VAULT_REPO_URL VAULT_REPO_REF VAULT_CHECKOUT_DIR
  export GRAYHAVEN_ENVIRONMENT GRAYHAVEN_HOSTNAME GRAYHAVEN_IS_CONTROL_NODE
  export GRAYHAVEN_CERTIFICATE_ENVIRONMENT GRAYHAVEN_TLS_MODE
  export ANSIBLE_VAULT_BIN
  export ANSIBLE_CONFIG="${CHECKOUT_DIR}/ansible.cfg"
  export HOME="$ANSIBLE_HOME"
  export USER="ansible"
  export LOGNAME="ansible"
  export ANSIBLE_COLLECTIONS_PATH
  export ANSIBLE_COLLECTIONS_PATHS="$ANSIBLE_COLLECTIONS_PATH"
  if running_as_ansible; then
    install -d -m 0755 "$RUNNER_WORK_DIR"
  else
    install -d -o ansible -g ansible -m 0755 "$RUNNER_WORK_DIR"
  fi
  cd "$RUNNER_WORK_DIR"

  log "Preparing checkouts."
  if running_as_ansible; then
    install -d -m 0755 "$CHECKOUT_PARENT"
  else
    install -d -o ansible -g ansible -m 0755 "$CHECKOUT_PARENT"
  fi
  prepare_github_known_hosts
  checkout_ref "$CHECKOUT_DIR" "$REPO_URL" "$REPO_REF"
  checkout_ref "$VAULT_CHECKOUT_DIR" "$VAULT_REPO_URL" "$VAULT_REPO_REF" "$VAULT_DEPLOY_PRIVATE_KEY"
  if ! running_as_ansible; then
    chown -R ansible:ansible "$CHECKOUT_DIR" "$VAULT_CHECKOUT_DIR"
  fi

  install_ansible_runtime
  render_secret_environment
  refresh_runtime_state_from_inventory

  if [[ ! "${DISCORD_WEBHOOK_URL:-}" =~ ^https://discord.com/api/webhooks/([^/]+)/([^/]+)$ ]]; then
    log "Discord webhook URL has an unexpected format."
    exit 1
  fi

  DISCORD_WEBHOOK_ID="${BASH_REMATCH[1]}"
  DISCORD_WEBHOOK_TOKEN="${BASH_REMATCH[2]}"
  export DISCORD_WEBHOOK_ID DISCORD_WEBHOOK_TOKEN

  render_runner_vars
}

run_convergence() {
  prepare_inventory_known_hosts

  log "Running full site playbook."
  install -m 0600 /dev/null "$RUNNER_PLAYBOOK_LOG"
  run_as_ansible "$ANSIBLE_PLAYBOOK_BIN" \
    --inventory "${CHECKOUT_DIR}/inventory" \
    "${CHECKOUT_DIR}/playbooks/site.yml" \
    --vault-password-file "$VAULT_PASSWORD_FILE" \
    --extra-vars "@${VAULT_CHECKOUT_DIR}/config.yml" \
    --extra-vars "@${VAULT_CHECKOUT_DIR}/vault/common.yml" \
    --extra-vars "@${VAULT_CHECKOUT_DIR}/vault/bastion.yml" \
    --extra-vars "@${VAULT_CHECKOUT_DIR}/vault/web.yml" \
    --extra-vars "@${RUNNER_VARS}" 2>&1 | tee "$RUNNER_PLAYBOOK_LOG"
}

run_gcs_restic_bucket_cleanup() {
  local delete_args=()

  if [[ "$GCS_CLEANUP_EXECUTE" == "true" ]]; then
    log "Running GCS restic bucket cleanup with deletion enabled."
    delete_args+=(--extra-vars "confirm_delete_remote_backup_buckets=true")
  else
    log "Running GCS restic bucket cleanup dry run."
  fi

  run_as_ansible "$ANSIBLE_PLAYBOOK_BIN" \
    --inventory "${CHECKOUT_DIR}/inventory" \
    "${CHECKOUT_DIR}/playbooks/cleanup-gcs-restic-buckets.yml" \
    --vault-password-file "$VAULT_PASSWORD_FILE" \
    --extra-vars "@${VAULT_CHECKOUT_DIR}/config.yml" \
    --extra-vars "@${VAULT_CHECKOUT_DIR}/vault/common.yml" \
    --extra-vars "@${VAULT_CHECKOUT_DIR}/vault/bastion.yml" \
    --extra-vars "@${RUNNER_VARS}" \
    "${delete_args[@]}"
}

extra_vars_file_args() {
  local extra_vars_file

  for extra_vars_file in "${RUNNER_EXTRA_VARS_FILES[@]}"; do
    printf '%s\n' "--extra-vars"
    printf '%s\n' "@${extra_vars_file}"
  done
}

prepare_rotate_vault_password_file() {
  local extra_vars_file
  local temp_password_file

  temp_password_file="$(mktemp "${RUNNER_RUNTIME_DIR}/vault-password.XXXXXX")"
  chmod 0600 "$temp_password_file"
  for extra_vars_file in "${RUNNER_EXTRA_VARS_FILES[@]}"; do
    /usr/bin/python3 - "$extra_vars_file" <<'PY' > "$temp_password_file"
import ast
import re
import sys

pattern = re.compile(r"^\s*new_vault_password\s*:\s*(?P<value>.+?)\s*$")
with open(sys.argv[1], encoding="utf-8") as vars_file:
    for line in vars_file:
        match = pattern.match(line)
        if not match:
            continue

        value = match.group("value")
        if value and value[0] in "\"'":
            value = ast.literal_eval(value)
        if isinstance(value, str) and value:
            print(value, end="")
        break
PY
    if [[ -s "$temp_password_file" ]]; then
      ROTATE_VAULT_PASSWORD_FILE="$temp_password_file"
      VAULT_PASSWORD_FILE="$ROTATE_VAULT_PASSWORD_FILE"
      export VAULT_PASSWORD_FILE
      return 0
    fi
  done

  rm -f "$temp_password_file"
  log "No new_vault_password value was found in the supplied extra-vars files."
  exit 1
}

run_rotate_vault_password() {
  local extra_args=()

  mapfile -t extra_args < <(extra_vars_file_args)
  log "Running vault password rotation maintenance playbook."
  run_as_ansible "$ANSIBLE_PLAYBOOK_BIN" \
    --inventory "${CHECKOUT_DIR}/inventory" \
    "${CHECKOUT_DIR}/playbooks/rotate-vault-password.yml" \
    --vault-password-file "$VAULT_PASSWORD_FILE" \
    "${extra_args[@]}"
}

run_rotate_vault_deploy_key() {
  log "Running vault deploy key rotation maintenance playbook."
  run_as_ansible "$ANSIBLE_PLAYBOOK_BIN" \
    --inventory "${CHECKOUT_DIR}/inventory" \
    "${CHECKOUT_DIR}/playbooks/rotate-vault-deploy-key.yml" \
    --vault-password-file "$VAULT_PASSWORD_FILE"
}

run_rotate_ansible_control_key() {
  local extra_args=()

  mapfile -t extra_args < <(extra_vars_file_args)
  log "Running Ansible control key rotation maintenance playbook."
  run_as_ansible "$ANSIBLE_PLAYBOOK_BIN" \
    --inventory "${CHECKOUT_DIR}/inventory" \
    "${CHECKOUT_DIR}/playbooks/rotate-ansible-control-key.yml" \
    --vault-password-file "$VAULT_PASSWORD_FILE" \
    --extra-vars "@${VAULT_CHECKOUT_DIR}/vault/bastion.yml" \
    "${extra_args[@]}"
}

run_once() {
  if [[ "$RUNNER_COMMAND" == "rotate-vault-password" ]]; then
    prepare_rotate_vault_password_file
  fi

  prepare_runner_runtime

  case "$RUNNER_COMMAND" in
    converge)
      run_convergence
      ;;
    cleanup-gcs-restic-buckets)
      run_gcs_restic_bucket_cleanup
      ;;
    rotate-vault-password)
      run_rotate_vault_password
      ;;
    rotate-vault-deploy-key)
      run_rotate_vault_deploy_key
      ;;
    rotate-ansible-control-key)
      run_rotate_ansible_control_key
      ;;
    *)
      log "Unsupported runner command: $RUNNER_COMMAND"
      exit 1
      ;;
  esac
}

main() {
  drop_to_ansible "$@"
  parse_args "$@"
  trap cleanup_runtime_files EXIT

  exec 9>"$LOCK_FILE"
  if ! flock -n 9; then
    if [[ "$RUNNER_COMMAND" == "converge" ]]; then
      log "Another runner invocation is already active; queueing follow-up run."
      touch "$PENDING_FILE"
      exit 0
    fi

    log "Another runner invocation is already active; manual command cannot start."
    exit 1
  fi

  trap on_error ERR

  if [[ "$RUNNER_COMMAND" != "converge" ]]; then
    run_once
    return
  fi

  while true; do
    rm -f "$PENDING_FILE"
    run_once
    write_convergence_metric 1 || log "Convergence success metric could not be written."

    if [[ ! -f "$PENDING_FILE" ]]; then
      break
    fi

    log "Pending runner request detected; starting another convergence pass."
  done
}

main "$@"
