#!/usr/bin/env python3
"""Render and validate the Time Tracker deployment templates."""

from __future__ import annotations

import argparse
import pathlib
import tempfile

import jinja2


REPO_ROOT = pathlib.Path(__file__).resolve().parents[1]
TEMPLATE_DIR = REPO_ROOT / "roles" / "timetracker" / "templates"
SERVICE_TASKS = REPO_ROOT / "roles" / "timetracker" / "tasks" / "service.yml"
NGINX_TASKS = REPO_ROOT / "roles" / "timetracker" / "tasks" / "nginx.yml"
TEMPLATES = {
    "grayhaven-timetracker.container.j2": "grayhaven-timetracker.container",
    "grayhaven-timetracker.conf.j2": "grayhaven-timetracker.conf",
}


def fixture_context() -> dict[str, object]:
    return {
        "grayhaven_timezone": "America/Chicago",
        "timetracker": {
            "backup_dir": "/var/lib/grayhaven/timetracker/backups",
            "branding_dir": "/var/lib/grayhaven/timetracker/branding",
            "data_dir": "/var/lib/grayhaven/timetracker/data",
            "hostname": "timetracker.example.invalid",
            "image_digest": "sha256:" + ("a" * 64),
            "secrets_dir": "/var/lib/grayhaven/timetracker/secrets",
        },
        "timetracker_container_name": "grayhaven-timetracker",
        "timetracker_container_port": 8000,
        "timetracker_database_filename": "timetracker.sqlite3",
        "timetracker_gid": 777,
        "timetracker_host_port": 8000,
        "timetracker_image_repository": "ghcr.io/example/grayhaven-timetracker",
        "timetracker_tls_mode": "host",
        "timetracker_uid": 777,
    }


def render_templates(output_dir: pathlib.Path) -> dict[str, str]:
    environment = jinja2.Environment(
        loader=jinja2.FileSystemLoader(TEMPLATE_DIR),
        autoescape=False,
        keep_trailing_newline=True,
    )
    rendered: dict[str, str] = {}
    output_dir.mkdir(parents=True, exist_ok=True)
    for template_name, output_name in TEMPLATES.items():
        content = environment.get_template(template_name).render(fixture_context())
        (output_dir / output_name).write_text(content, encoding="utf-8")
        rendered[output_name] = content
    return rendered


def validate(rendered: dict[str, str]) -> None:
    quadlet = rendered["grayhaven-timetracker.container"]
    nginx = rendered["grayhaven-timetracker.conf"]
    service_tasks = SERVICE_TASKS.read_text(encoding="utf-8")
    nginx_tasks = NGINX_TASKS.read_text(encoding="utf-8")
    required_quadlet = (
        "Image=ghcr.io/example/grayhaven-timetracker@sha256:",
        "PublishPort=127.0.0.1:8000:8000",
        "Environment=GUNICORN_CMD_ARGS=--no-control-socket",
        "headers={'Host': 'timetracker.example.invalid'}",
        "NoNewPrivileges=true",
        "PidsLimit=128",
        "ReadOnly=true",
        "Notify=healthy",
    )
    required_nginx = (
        "server_name timetracker.example.invalid;",
        "proxy_pass http://127.0.0.1:8000;",
        "proxy_set_header X-Forwarded-Proto https;",
        "location = /health",
        "/shared/reports/[redacted]",
    )
    missing = [
        value
        for value in (*required_quadlet, *required_nginx)
        if value not in (quadlet if value in required_quadlet else nginx)
    ]
    if missing:
        raise RuntimeError(f"Rendered Time Tracker configuration is missing: {missing}")
    if "0.0.0.0:8000" in quadlet:
        raise RuntimeError("Time Tracker container port must remain loopback-only")
    required_service_probe = (
        'url: "http://127.0.0.1:{{ timetracker_host_port }}/health"',
        'Host: "{{ timetracker.hostname }}"',
    )
    missing_service_probe = [
        value for value in required_service_probe if value not in service_tasks
    ]
    if missing_service_probe:
        raise RuntimeError(
            "Time Tracker service health probe is missing: "
            f"{missing_service_probe}"
        )
    required_nginx_tasks = (
        "ansible.posix.seboolean:",
        "name: httpd_can_network_connect",
        "state: true",
        "persistent: true",
    )
    missing_nginx_tasks = [
        value for value in required_nginx_tasks if value not in nginx_tasks
    ]
    if missing_nginx_tasks:
        raise RuntimeError(
            "Time Tracker nginx SELinux policy is missing: "
            f"{missing_nginx_tasks}"
        )


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--keep-rendered",
        metavar="DIRECTORY",
        help="write rendered files to DIRECTORY instead of a temporary directory",
    )
    args = parser.parse_args()

    if args.keep_rendered:
        validate(render_templates(pathlib.Path(args.keep_rendered)))
        return 0
    with tempfile.TemporaryDirectory(prefix="grayhaven-timetracker.") as temp_dir:
        validate(render_templates(pathlib.Path(temp_dir)))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
