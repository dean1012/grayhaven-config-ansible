#!/usr/bin/env python3
"""Render and validate the Grafana Alloy template with synthetic values."""

from __future__ import annotations

import argparse
import json
import pathlib
import re
import subprocess
import sys
import tempfile

import jinja2


REPO_ROOT = pathlib.Path(__file__).resolve().parents[1]
TEMPLATE_DIR = REPO_ROOT / "roles" / "observability" / "templates"
TEMPLATE_NAME = "config.alloy.j2"


def regex_replace(value: object, pattern: str, replacement: str) -> str:
    return re.sub(pattern, replacement, str(value))


def build_environment() -> jinja2.Environment:
    environment = jinja2.Environment(
        loader=jinja2.FileSystemLoader(TEMPLATE_DIR),
        autoescape=False,
        keep_trailing_newline=True,
    )
    environment.filters["regex_replace"] = regex_replace
    environment.filters["string"] = str
    environment.filters["to_json"] = json.dumps
    return environment


def fixture_context() -> dict[str, object]:
    return {
        "grayhaven_role": "web",
        "inventory_hostname": "grayhaven-core-prod-web-01.grayhavensystems.com",
        "grayhaven_environment": "prod",
        "observability_alloy_token_file": "/etc/grayhaven/observability/grafana-alloy-token",
        "observability_client": "grayhaven",
        "observability_grafana_credentials": {
            "loki": {
                "push_url": "https://logs.example.invalid/loki/api/v1/push",
                "username": "654321",
            },
            "prometheus": {
                "remote_write_url": "https://prometheus.example.invalid/api/prom/push",
                "username": "123456",
            },
        },
        "observability_logs_enabled": True,
        "observability_project": "core",
        "observability_role": "web",
        "observability_short_hostname": "grayhaven-core-prod-web-01",
        "observability_textfile_dir": "/var/lib/grayhaven/observability/textfile",
        "observability_web_sites": [
            {
                "aliases": ["www.grayhavensystems.com"],
                "dev_domain": "dev.grayhavensystems.com",
                "domain": "grayhavensystems.com",
                "kind": "website",
                "nginx_log_names": [
                    "prod.access",
                    "prod.error",
                    "dev.access",
                    "dev.error",
                ],
                "root_name": "grayhavensystems.com",
            },
            {
                "aliases": ["www.jerry-smith.net"],
                "dev_domain": "dev.jerry-smith.net",
                "domain": "jerry-smith.net",
                "kind": "website",
                "nginx_log_names": [
                    "prod.access",
                    "prod.error",
                    "dev.access",
                    "dev.error",
                ],
                "root_name": "jerry-smith.net",
            },
            {
                "aliases": [],
                "dev_domain": "",
                "domain": "timetracker.grayhavensystems.com",
                "kind": "application",
                "nginx_log_names": ["access", "error"],
                "root_name": "timetracker",
            },
        ],
    }


def render_config(output_path: pathlib.Path) -> None:
    template = build_environment().get_template(TEMPLATE_NAME)
    output_path.write_text(template.render(fixture_context()), encoding="utf-8")


def main() -> int:
    parser = argparse.ArgumentParser()
    parser.add_argument(
        "--keep-rendered",
        metavar="PATH",
        help="write the rendered Alloy file to PATH instead of a temporary file",
    )
    args = parser.parse_args()

    with tempfile.TemporaryDirectory(prefix="grayhaven-alloy.") as temp_dir:
        rendered_path = pathlib.Path(args.keep_rendered or pathlib.Path(temp_dir) / "config.alloy")
        rendered_path.parent.mkdir(parents=True, exist_ok=True)
        render_config(rendered_path)
        try:
            result = subprocess.run(["alloy", "validate", str(rendered_path)], check=False)
        except FileNotFoundError:
            print("alloy is required to validate rendered Alloy configuration", file=sys.stderr)
            return 127
        return result.returncode


if __name__ == "__main__":
    sys.exit(main())
